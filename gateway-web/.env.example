# book-mall 主站地址
BOOK_MALL_ORIGIN=http://localhost:3000
NEXT_PUBLIC_BOOK_MALL_ORIGIN=http://localhost:3000

# 本站点对外地址（SSO 回调等）
GATEWAY_PUBLIC_ORIGIN=http://localhost:3005

# 必须与 book-mall .env.local 中 GATEWAY_SSO_SERVER_SECRET（或 TOOLS_SSO_SERVER_SECRET）完全一致
GATEWAY_SSO_SERVER_SECRET=change-me-to-a-long-secret-min-16-chars
