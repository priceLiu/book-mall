# next dev 自动加载（优先级低于 .env*.local）。本地请仍用 .env.local 存放密钥与模型 Key。
MAIN_SITE_ORIGIN=http://localhost:3000
NEXT_PUBLIC_MAIN_SITE_ORIGIN=http://localhost:3000
TOOLS_PUBLIC_ORIGIN=http://localhost:3001

# finance-web（与 book-mall NEXT_PUBLIC_FINANCE_WEB_ORIGIN 一致）：费用页「财务控制台」外链
NEXT_PUBLIC_FINANCE_WEB_ORIGIN=http://localhost:3002

# story-web（漫剧个人空间）：漫剧剧场「创作幻想家」外链
NEXT_PUBLIC_STORY_WEB_ORIGIN=http://localhost:3003

# canvas-web（AI 海报画布）：AI 海报画布 → 创意画室 外链
NEXT_PUBLIC_CANVAS_WEB_ORIGIN=http://localhost:3004

# gateway-web BYOK 控制台
NEXT_PUBLIC_GATEWAY_WEB_ORIGIN=http://localhost:3005

# prompt-optimizer-platform（提示词优化器）
NEXT_PUBLIC_PROMPT_OPTIMIZER_ORIGIN=http://localhost:3006
