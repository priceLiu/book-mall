# 将下列变量写入本目录（tool-web/）下的 .env.local（本模板不进运行时）。
#
# —— 与主站联调 SSO（必填）
MAIN_SITE_ORIGIN=http://localhost:3000
TOOLS_SSO_SERVER_SECRET=
# 与主站 TOOLS_SSO_JWT_SECRET 完全一致（必填以启用 JWT 快路径，否则首屏常走 introspect，Neon 休眠时可达 10～20 秒）
TOOLS_SSO_JWT_SECRET=
# 与主站一致；设为 1 时 `/api/tools-session` JSON 附带 `_diag` + **服务端控制台**摘要（生产勿长期开）
# 本地 development 下不配此项也会在终端打印会话摘要。
# TOOLS_DIAGNOSTICS=1
# 回落 introspect 时的 fetch 超时（毫秒），默认 12000
# TOOLS_INTROSPECT_TIMEOUT_MS=12000

# —— 文生图 / OpenAI 兼容接口（仅在工具站使用；勿写入 book-mall）
# TOOL_WEB_OPENAI_COMPAT_API_KEY=
# TOOL_WEB_OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# TOOL_WEB_IMAGE_MODEL=gpt-image-1
