# 主站地址（无末尾 /），本地示例 http://localhost:3000
MAIN_SITE_ORIGIN=http://localhost:3000

# 与主站 book-mall/.env.local 中完全一致（≥16 字符随机串）
TOOLS_SSO_SERVER_SECRET=

# 必填：与 book-mall/.env.local 中 TOOLS_SSO_JWT_SECRET 完全一致（≥16 位）。
# 未配置时壳层与页面每次都会请求主站 introspect（Neon 休眠时整个首屏可达 10～20 秒）。
TOOLS_SSO_JWT_SECRET=

# 阿里云百炼（中国内地）：AI 试衣（aitryon）、通义文生图（wanx）等均可用同一 API Key（服务端读取）
DASHSCOPE_API_KEY=
# 可选，默认 aitryon；高质量可用 aitryon-plus（计费不同，见阿里云文档）
# DASHSCOPE_TRYON_MODEL=aitryon

# 试衣：Data URL 会先上传到阿里云 OSS，再传公网 URL 给百炼（须 Bucket 可读）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# Bucket 名称，例如 tool-mall 对应 tool-mall.oss-cn-guangzhou.aliyuncs.com
OSS_BUCKET=
# 可选，默认 oss-cn-guangzhou；须与 Bucket 地域一致（勿写成 oss-cn-gangzhou）
# OSS_REGION=oss-cn-guangzhou
# 可选，默认由 SDK 根据 OSS_REGION 推导 HTTPS 公网 Endpoint（推荐不设，避免与地域不一致）
# OSS_ENDPOINT=https://oss-cn-guangzhou.aliyuncs.com
# 可选：自定义访问域名/CDN 根（无末尾 /），用于替换 SDK 返回的默认 URL
# OSS_PUBLIC_URL_BASE=https://tool-mall.oss-cn-guangzhou.aliyuncs.com
# TOOL_WEB_OPENAI_COMPAT_API_KEY=
# TOOL_WEB_OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# TOOL_WEB_IMAGE_MODEL=gpt-image-1
