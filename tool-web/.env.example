# 复制为 .env.local（勿提交仓库）。
#
# —— 主站与 SSO（TOOLS_SSO_* 须与 book-mall/.env.local 完全一致）——
MAIN_SITE_ORIGIN=http://localhost:3000
TOOLS_PUBLIC_ORIGIN=http://localhost:3001
TOOLS_SSO_SERVER_SECRET=
TOOLS_SSO_JWT_SECRET=

# —— 阿里云百炼 / OSS（按需）——
DASHSCOPE_API_KEY=
# DASHSCOPE_TRYON_MODEL=aitryon

OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
# OSS_REGION=oss-cn-guangzhou
# OSS_ENDPOINT=
# OSS_PUBLIC_URL_BASE=

# —— DeepSeek（AI智能客服对话，服务端）——
# DEEPSEEK_API_KEY=

# —— Dify 网站嵌入（对话页右侧；token 与控制台嵌入代码一致，会进入前端 bundle）——
# NEXT_PUBLIC_DIFY_EMBED_TOKEN=

# —— 文生图 OpenAI 兼容（可选，与 DashScope 二选一亦可）——
# TOOL_WEB_OPENAI_COMPAT_API_KEY=
# TOOL_WEB_OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# TOOL_WEB_IMAGE_MODEL=gpt-image-1

# 可选
# QWEN_API_KEY=
# TOOLS_DIAGNOSTICS=1
# TOOLS_INTROSPECT_TIMEOUT_MS=12000
# FIT_IMAGE_PROXY_STRICT_TLS=1
