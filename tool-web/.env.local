# 本地联调：与 book-mall/.env.local 中两项 Secret 必须一致（JWT 启用壳层/页面零 introspect 快路径）
MAIN_SITE_ORIGIN=http://localhost:3000
TOOLS_SSO_SERVER_SECRET=bm-local-tools-sso-srv-2026-change-for-production-key-min16
TOOLS_SSO_JWT_SECRET=bm-local-tools-sso-jwt-2026-change-for-production-key-min16

# 须与 book-mall TOOLS_PUBLIC_ORIGIN 完全一致；Cookie 只挂在该主机——请用浏览器打开同一主机（勿混 localhost / 127）
TOOLS_PUBLIC_ORIGIN=http://localhost:3001
