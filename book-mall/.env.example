# 复制为 .env.local（勿提交仓库）。Prisma / Next 相关脚本默认通过 dotenv-cli 读取 .env.local。
# `pnpm dev` 时若未在本文件出现的键写在 .env.local，可沿用目录内 .env.development 的 localhost 默认项（.env.local 优先）。
#
# DATABASE_URL：务必使用 Neon 控制台里的 **Connection pooling** 字符串（主机多为 …pooler.neon.tech）。
# 推荐追加参数：sslmode=require&pgbouncer=true&connect_timeout=45（勿用 channel_binding=require）。
# 若 dev 控制台反复出现 prisma:error … connection Closed，多半是误用了「直连 / unpooled」或本地 TCP 被远端回收。
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_EP_POOLER.neon.tech:5432/neondb?sslmode=require&pgbouncer=true&connect_timeout=45

# 本地开发（默认）
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# 生产示例（云托管控制台 / deploy/tencent/book-mall.env；勿提交真实密钥）：
# NEXTAUTH_URL=https://book.ai-code8.com
# TOOLS_PUBLIC_ORIGIN=https://tool.ai-code8.com
# 若控制台暂时仍填云托管默认 URL，可单独设签发用自定义域（须与浏览器打开工具站一致）：
# TOOLS_SSO_ISSUE_ORIGIN=https://tool.ai-code8.com

ADMIN_EMAILS=

# —— 工具站 SSO（TOOLS_SSO_* 须与 tool-web/.env.local 完全一致）——
TOOLS_PUBLIC_ORIGIN=http://localhost:3001
TOOLS_SSO_SERVER_SECRET=
TOOLS_SSO_JWT_SECRET=

# 可选
# TOOLS_SSO_CODE_TTL_SECONDS=90
# TOOLS_SSO_JWT_TTL_SECONDS=600
# TOOLS_SSO_RELAX_MEMBERSHIP=1
# TOOLS_DIAGNOSTICS=1
# ALLOW_MOCK_PAYMENT=true

# —— OSS（与 tool-web 一致；删除图片/视频库记录时会尝试 deleteObject）——
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_REGION=oss-cn-guangzhou
# OSS_ENDPOINT=
# OSS_PUBLIC_URL_BASE=

# 详见 doc/tech/tools-sso-environment.md、仓库根目录 deploy.md
