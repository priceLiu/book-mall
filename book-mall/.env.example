# —— story-web 三期：AI 创作生产线（详见 story-web/docs/ai/plan.md §3）——
# KIE.AI 一把 key 管 LLM + 图像 + 视频（从 story-web/.env.local 迁移）：
#   - LLM：POST {KIE_API_BASE}/gemini-3-flash/v1/chat/completions（OpenAI Chat Completions 兼容）
#   - 图像：nano-banana-pro
#   - 视频：wan/2-7-image-pro
# canvas v2 · 漫剧 Story LLM 系统 Provider（system:deepseek · OpenAI 兼容）
# DEEPSEEK_API_KEY=
# KIE_API_KEY=
# KIE_API_BASE=https://api.kie.ai
# 百炼 DashScope · 画布参考生视频（HappyHorse / 万相 R2V）；与 tool-web 同变量
# DASHSCOPE_API_KEY=
# 火山方舟 / 豆包（Gateway VOLCENGINE 凭证 · ark- API Key + IAM AK/SK，seed 脚本写入 Gateway）
# VOLCENGINE_API_KEY=
# VOLCENGINE_ACCESS_KEY=          # 或 VOLCENGINE_ACCESS_KEY_ID / VOLCENGINE_AK
# VOLCENGINE_SECRET_ACCESS_KEY=   # 或 VOLCENGINE_SECRET_KEY / VOLCENGINE_SK
# 可选：OpenAPI Host（默认 open.volcengineapi.com）
# VOLCENGINE_OPENAPI_HOST=open.volcengineapi.com
# KIE_CALLBACK_TOKEN=
# 可选：覆盖 LLM 端点（例如换自部署 OpenAI 兼容网关）
# STORY_AI_GEMINI_ENDPOINT=
# 公网回调基址。为空时不下发 callBackUrl，纯靠 poll worker（决议 §13.6）
# 生产示例：STORY_AI_PUBLIC_BASE=https://book.ai-code8.com
# STORY_AI_PUBLIC_BASE=
# 轮询/清理 worker 的 Bearer token（与腾讯云托管定时任务一致）
# STORY_AI_POLL_TOKEN=
# 上游并发软上限（可选，默认值见代码）
# STORY_AI_USER_INFLIGHT_MAX=50
# STORY_AI_KIE_MAX_CONCURRENCY=10
# STORY_AI_LLM_MAX_CONCURRENCY=5

# —— 统一积分计费 + 单会话（book-mall）——
# CREDIT_BILLING_OFF=1          # 设为 1 关闭新积分体系（回退旧钱包）
# SINGLE_SESSION_ENFORCE=1      # 新登录挤掉旧会话（本地测试建议开启）
# SINGLE_SESSION_RECHECK_SEC=60 # JWT 内 sv 重校验间隔（秒）
