# 复制为 .env.local（勿提交仓库）。Prisma / Next 相关脚本默认通过 dotenv-cli 读取 .env.local。
# `pnpm dev` 时若未在本文件出现的键写在 .env.local，可沿用目录内 .env.development 的 localhost 默认项（.env.local 优先）。
#
# DATABASE_URL：务必使用 Neon 控制台里的 **Connection pooling** 字符串（主机多为 …pooler.neon.tech）。
# 推荐追加参数：sslmode=require&pgbouncer=true&connect_timeout=45（勿用 channel_binding=require）。
# 若 dev 控制台反复出现 prisma:error … connection Closed，多半是误用了「直连 / unpooled」或本地 TCP 被远端回收。
# 若出现「Timed out fetching a new connection from the connection pool」，可在 URL 末尾追加
# &pool_timeout=30&connection_limit=N。
# - Neon pooled（pgbouncer）：N 可较大（如 10~15），pgbouncer 会多路复用。
# - 腾讯云 PostgreSQL 直连（无 pgbouncer，主机 …tencentcdb.com）：dev:all 推荐 **30**（DB max_connections 余量大），
#   太小（如 10）会在几个慢查询/瞬时网络抖动时占满池 → 请求排队到 pool_timeout → 卡死。
#   估算 book-mall(web 1 进程 × N) + poll-loop(3 × PRISMA_CONNECTION_LIMIT=1) ≤ max_connections。
#   推荐完整示例：…/tool_mall?sslmode=disable&connection_limit=30&pool_timeout=30&connect_timeout=15
# 也可设 PRISMA_CONNECTION_LIMIT / PRISMA_POOL_TIMEOUT（Gen-HotCold-R2 Phase 6 起，所有环境在
# URL 未显式带 connection_limit 时都会注入连接预算，生产默认 10、开发默认 30）。
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_EP_POOLER.neon.tech:5432/neondb?sslmode=require&pgbouncer=true&connect_timeout=45

# 迁移/introspect 专用直连串（prisma schema 的 datasource.directUrl 引用，必填）。
#  - 经 PgBouncer(transaction 模式)时,DATABASE_URL 走池端口(:6432, pgbouncer=true)，
#    但 prisma migrate/db:deploy 必须直连 → 这里填**直连主机**(如 CDB:24155 或 Neon 非 pooler 主机)。
#  - 无 pooler(本地/直连)时,填与 DATABASE_URL 同库的直连串即可(行为不变)。
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@YOUR_DIRECT_HOST:5432/neondb?sslmode=require&connect_timeout=30

# Gen-HotCold-R2 Phase 6 · 只读副本（可选）。配置后报表/状态仪表盘等重读自动路由到副本，卸载主库写压力。
# 留空则报表读回退主库（行为不变）。副本只读，严禁写入；建议同样带 connection_limit/pool_timeout。
# DATABASE_REPLICA_URL=postgresql://USER:PASSWORD@YOUR_READONLY_REPLICA_HOST:5432/neondb?sslmode=require&connection_limit=10&pool_timeout=30
#
# 生产连接预算（PgBouncer / 连接池）建议：
#   - 优先在 DB 前置 PgBouncer（transaction pooling），Web 与各 poll-loop 子进程共享池，URL 走 pgbouncer 端口。
#   - 连接预算估算：web(1 × connection_limit) + poll-loop(N 进程 × PRISMA_CONNECTION_LIMIT=1) ≤ DB max_connections。
#   - generation-worker（canvas/story/gateway poll-loop）必须独立进程运行，Web 进程默认不跑重 poll
#     （读路径兜底由 CANVAS_OPPORTUNISTIC_POLL 控制，生产保持关闭）。
#
# Gen-HotCold-R3（动静分离，详见 doc/product/gen-hotcold-policy.md）：
#   GATEWAY_LOG_HOT_RETENTION_HOURS=1   # 主表热保留；cron hotcold:archive --only=gateway
#   CANVAS_TASK_TERMINAL_HOT_HOURS=6    # 画布 /tasks 轻量读终态窗

# 本地开发（默认）
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# 生产示例（云托管控制台 / deploy/tencent/book-mall.env；勿提交真实密钥）：
# NEXTAUTH_URL=https://book.ai-code8.com
# TOOLS_PUBLIC_ORIGIN=https://tool.ai-code8.com
# 若控制台暂时仍填云托管默认 URL，可单独设签发用自定义域（须与浏览器打开工具站一致）：
# TOOLS_SSO_ISSUE_ORIGIN=https://tool.ai-code8.com

ADMIN_EMAILS=
# 手机号管理员 bootstrap（seed 时提升 role=ADMIN；与 ADMIN_EMAILS 二选一或并用）
ADMIN_PHONES=

# —— 短信验证（默认 mock，生产改 tencent 并填腾讯云参数）——
SMS_PROVIDER=mock
# TENCENT_SMS_SECRET_ID=
# TENCENT_SMS_SECRET_KEY=
# TENCENT_SMS_REGION=ap-guangzhou
# TENCENT_SMS_SDK_APP_ID=
# TENCENT_SMS_SIGN_NAME=
# TENCENT_SMS_TEMPLATE_REGISTER=
# TENCENT_SMS_TEMPLATE_LOGIN=
# TENCENT_SMS_TEMPLATE_BIND=
# TENCENT_SMS_TEMPLATE_TEAM_INVITE=

# 开发测试登录 /dev/auth（非 development 时显式开启）
# ALLOW_DEV_AUTH=true
# NEXT_PUBLIC_ALLOW_DEV_AUTH=1

# 短信未正式开通前允许 8 位 bypass 码（6 字母+2 数字）；开通后生产务必设为 0
# SMS_ALLOW_BYPASS_CODE=0

# Google 登录已下线；以下项保留兼容旧环境，勿再启用
# NEXT_PUBLIC_AUTH_GOOGLE=1

# —— 工具站 SSO（TOOLS_SSO_* 须与 tool-web/.env.local 完全一致）——
TOOLS_PUBLIC_ORIGIN=http://localhost:3001
TOOLS_SSO_SERVER_SECRET=
TOOLS_SSO_JWT_SECRET=

# 可选
# TOOLS_SSO_CODE_TTL_SECONDS=90
# TOOLS_SSO_JWT_TTL_SECONDS=600
# TOOLS_SSO_RELAX_MEMBERSHIP=1

# —— Gateway BYOK 代理（gateway-web :3005，须与 gateway-web/.env.local 对齐）——
GATEWAY_PUBLIC_ORIGIN=http://localhost:3005
# book-mall 服务端自调 /api/gw/v1（零旁路；本地与 NEXTAUTH_URL 一致即可）
BOOK_MALL_ORIGIN=http://localhost:3000
# book-mall 服务端调 /api/gw/v1 时鉴权（可与 GATEWAY_SSO_SERVER_SECRET 相同）
# GATEWAY_INTERNAL_INVOKE_SECRET=
# 可与 TOOLS_SSO_SERVER_SECRET / TOOLS_SSO_JWT_SECRET 共用，或单独配置
GATEWAY_SSO_SERVER_SECRET=
GATEWAY_JWT_SECRET=
# GATEWAY_SSO_CODE_TTL_SEC=120
# GATEWAY_JWT_TTL_SEC=86400
# GATEWAY_KIE_CALLBACK_TOKEN=
# GATEWAY_POLL_INTERVAL_MS=10000
# —— 视频生成自动调控 · poll 调度（《视频生成自动调控 1.0》§6；均有代码默认值）——
# 火山纯轮询 · 厂商 ~50 并发 → 预算须 ≥ 并发上限，否则尾部任务饿死（收口延迟几十分钟）
# GATEWAY_POLL_VOLCENGINE_BUDGET=60
# 其它异步轮询厂商（百炼 / dashscope / 混元）预算
# GATEWAY_POLL_OTHER_BUDGET=24
# 回调型厂商（KIE）poll 仅兜底补捞条数 + 久未 poll 阈值
# GATEWAY_POLL_CALLBACK_BACKSTOP=8
# GATEWAY_POLL_CALLBACK_BACKSTOP_STALE_MS=90000
# poll 有限并发（保证 (预算之和/并发)×单次poll秒 < tick 间隔）
# GATEWAY_POLL_CONCURRENCY=8
# L2 兜底：火山 RUNNING 超过此 ms 未被 poll → 主动核对收口；单 tick 处理上限
# GATEWAY_VOLCENGINE_STALL_RECOVER_MS=120000
# GATEWAY_VOLCENGINE_STALL_RECOVER_LIMIT=12
# 火山在飞硬上限（设计·未启用，dispatch 侧；确认 50 是按账号/按 key 后再开）
# CANVAS_VOLCENGINE_INFLIGHT_CEILING=45
# TOOLS_DIAGNOSTICS=1
# ALLOW_MOCK_PAYMENT=true

# —— 微信个人收款（Checkout 中台）——
# WECHAT_PAYEE_NAME=收款人姓名
# WECHAT_PERSONAL_QR_URL=/payments/wechat-personal-qr.png
# PAYMENT_CHECKOUT_EXPIRE_HOURS=24

