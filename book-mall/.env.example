# 复制为 .env.local（勿提交仓库）。Prisma / Next 相关脚本默认通过 dotenv-cli 读取 .env.local。
# `pnpm dev` 时若未在本文件出现的键写在 .env.local，可沿用目录内 .env.development 的 localhost 默认项（.env.local 优先）。
#
# DATABASE_URL：务必使用 Neon 控制台里的 **Connection pooling** 字符串（主机多为 …pooler.neon.tech）。
# 推荐追加参数：sslmode=require&pgbouncer=true&connect_timeout=45（勿用 channel_binding=require）。
# 若 dev 控制台反复出现 prisma:error … connection Closed，多半是误用了「直连 / unpooled」或本地 TCP 被远端回收。
# 若出现「Timed out fetching a new connection from the connection pool」，可在 URL 末尾追加
# &pool_timeout=30&connection_limit=N。
# - Neon pooled（pgbouncer）：N 可较大（如 10~15），pgbouncer 会多路复用。
# - 腾讯云 PostgreSQL 直连（无 pgbouncer，主机 …tencentcdb.com）：N 适中（dev:all 推荐 **10**，勿超过 15），
#   因直连会占用 DB max_connections；估算 book-mall(web 1 进程 × N) + poll-loop(3 × PRISMA_CONNECTION_LIMIT=1) ≤ max_connections。
#   推荐完整示例：…/tool_mall?sslmode=disable&connection_limit=10&pool_timeout=30&connect_timeout=15
# 也可设 PRISMA_CONNECTION_LIMIT / PRISMA_POOL_TIMEOUT（lib/prisma.ts 仅在 URL 未显式带该参数时，开发态自动注入）。
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_EP_POOLER.neon.tech:5432/neondb?sslmode=require&pgbouncer=true&connect_timeout=45

# 本地开发（默认）
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# 生产示例（云托管控制台 / deploy/tencent/book-mall.env；勿提交真实密钥）：
# NEXTAUTH_URL=https://book.ai-code8.com
# TOOLS_PUBLIC_ORIGIN=https://tool.ai-code8.com
# 若控制台暂时仍填云托管默认 URL，可单独设签发用自定义域（须与浏览器打开工具站一致）：
# TOOLS_SSO_ISSUE_ORIGIN=https://tool.ai-code8.com

ADMIN_EMAILS=
# 手机号管理员 bootstrap（seed 时提升 role=ADMIN；与 ADMIN_EMAILS 二选一或并用）
ADMIN_PHONES=

# —— 短信验证（默认 mock，生产改 tencent 并填腾讯云参数）——
SMS_PROVIDER=mock
# TENCENT_SMS_SECRET_ID=
# TENCENT_SMS_SECRET_KEY=
# TENCENT_SMS_REGION=ap-guangzhou
# TENCENT_SMS_SDK_APP_ID=
# TENCENT_SMS_SIGN_NAME=
# TENCENT_SMS_TEMPLATE_REGISTER=
# TENCENT_SMS_TEMPLATE_LOGIN=
# TENCENT_SMS_TEMPLATE_BIND=
# TENCENT_SMS_TEMPLATE_TEAM_INVITE=

# 开发测试登录 /dev/auth（非 development 时显式开启）
# ALLOW_DEV_AUTH=true
# NEXT_PUBLIC_ALLOW_DEV_AUTH=1

# 短信未正式开通前允许 8 位 bypass 码（6 字母+2 数字）；开通后生产务必设为 0
# SMS_ALLOW_BYPASS_CODE=0

# Google 登录已下线；以下项保留兼容旧环境，勿再启用
# NEXT_PUBLIC_AUTH_GOOGLE=1

# —— 工具站 SSO（TOOLS_SSO_* 须与 tool-web/.env.local 完全一致）——
TOOLS_PUBLIC_ORIGIN=http://localhost:3001
TOOLS_SSO_SERVER_SECRET=
TOOLS_SSO_JWT_SECRET=

# 可选
# TOOLS_SSO_CODE_TTL_SECONDS=90
# TOOLS_SSO_JWT_TTL_SECONDS=600
# TOOLS_SSO_RELAX_MEMBERSHIP=1

# —— Gateway BYOK 代理（gateway-web :3005，须与 gateway-web/.env.local 对齐）——
GATEWAY_PUBLIC_ORIGIN=http://localhost:3005
# book-mall 服务端自调 /api/gw/v1（零旁路；本地与 NEXTAUTH_URL 一致即可）
BOOK_MALL_ORIGIN=http://localhost:3000
# book-mall 服务端调 /api/gw/v1 时鉴权（可与 GATEWAY_SSO_SERVER_SECRET 相同）
# GATEWAY_INTERNAL_INVOKE_SECRET=
# 可与 TOOLS_SSO_SERVER_SECRET / TOOLS_SSO_JWT_SECRET 共用，或单独配置
GATEWAY_SSO_SERVER_SECRET=
GATEWAY_JWT_SECRET=
# GATEWAY_SSO_CODE_TTL_SEC=120
# GATEWAY_JWT_TTL_SEC=86400
# GATEWAY_KIE_CALLBACK_TOKEN=
# GATEWAY_POLL_INTERVAL_MS=10000
# TOOLS_DIAGNOSTICS=1
# ALLOW_MOCK_PAYMENT=true

# —— 微信个人收款（Checkout 中台）——
# WECHAT_PAYEE_NAME=收款人姓名
# WECHAT_PERSONAL_QR_URL=/payments/wechat-personal-qr.png
# PAYMENT_CHECKOUT_EXPIRE_HOURS=24

# —— OSS（与 tool-web 一致；删除图片/视频库记录时会尝试 deleteObject）——
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_REGION=oss-cn-guangzhou
# OSS_ENDPOINT=
# OSS_PUBLIC_URL_BASE=

# 详见 doc/tech/tools-sso-environment.md、仓库根目录 deploy.md

# —— finance-web 跨源拉取明细（可选）——
# 个人中心「费用与明细」外链（须与 finance-web 部署根地址一致；与 tool-web 同变量名）
# NEXT_PUBLIC_FINANCE_WEB_ORIGIN=http://localhost:3002
# 允许的来源，逗号分隔；需与 finance-web 浏览器 Origin 一致。
# FINANCE_WEB_ORIGINS=http://localhost:3002

# story-web（npm run dev -p 3003）：漫剧个人空间 CORS
# NEXT_PUBLIC_STORY_WEB_ORIGIN=http://localhost:3003
# STORY_WEB_ORIGINS=http://localhost:3003

# canvas-web（npm run dev -p 3004）：AI 海报画布 CORS
# NEXT_PUBLIC_CANVAS_WEB_ORIGIN=http://localhost:3004
# CANVAS_WEB_ORIGINS=http://localhost:3004
# CANVAS_CORS_IN_APP=1

# prompt-optimizer-platform（npm run dev -p 3006）
# NEXT_PUBLIC_PROMPT_OPTIMIZER_ORIGIN=http://localhost:3006
# PROMPT_OPTIMIZER_PUBLIC_ORIGIN=http://localhost:3006

# quick-replica-web（pnpm --dir quick-replica-web dev · :3008）
# NEXT_PUBLIC_QUICK_REPLICA_ORIGIN=http://localhost:3008
# QUICK_REPLICA_PUBLIC_ORIGIN=http://localhost:3008

# e-commerce-toolkit（pnpm --dir e-commerce-toolkit dev · :3007）
# NEXT_PUBLIC_ECOMMERCE_WEB_ORIGIN=http://localhost:3007
# ECOMMERCE_PUBLIC_ORIGIN=http://localhost:3007
# 6a 平台代付（已废弃共享 Key）：现用 per-user 托管 sk-gw，凭证来自：
# 平台代付凭证池 canonical 归属（默认 13808816802@126.com）
# PLATFORM_POOL_OWNER_EMAIL=13808816802@126.com
# 可在 Gateway 管理厂商 Key 的 Book 管理员（逗号分隔，会复制 canonical 凭证副本）
# PLATFORM_GATEWAY_ADMIN_EMAILS=13808816802@126.com,admin@126.com
# PLATFORM_VENDOR_CREDENTIAL_IDS=cred_xxx,cred_yyy
# 或从已有 PLATFORM sk-gw 复制绑定：PLATFORM_GATEWAY_API_KEY_ID=
# ECOM_PLATFORM_GATEWAY_API_KEY_ID=  # 遗留，勿再用于新部署
# canvas v2 · 用户 Provider API Key 加密密钥（base64 编码 32 字节）
# 生成：openssl rand -base64 32
# CANVAS_SECRET_KEY=
# 腾讯混元生3D（三视图引擎 · 系统 Provider system:hunyuan-3d）
# 专业版 Key（api.ai3d.cloud.tencent.com · OpenAI 兼容）
# HUNYUAN_3D_API_KEY=
# 极速版 / 普通版 · 官方 API（ai3d.tencentcloudapi.com · TC3 签名）
# HUNYUAN_TC_SECRET_ID=
# HUNYUAN_TC_SECRET_KEY=
# HUNYUAN_TC_REGION=ap-guangzhou
# 极速版 · TokenHub（可选，与官方 API 不是同一套凭证）
# HUNYUAN_TOKENHUB_API_KEY=
# HUNYUAN_3D_API_BASE=https://api.ai3d.cloud.tencent.com
# 仅开发：允许用 ?devUserId=<User.id> 代替 Cookie（勿在生产开启）
# FINANCE_ALLOW_DEV_USER_QUERY=1

# —— 云账单 CSV 导入（pnpm billing:import-cloud-csv）——
# BILLING_IMPORT_PRICING_TEMPLATE=aliyun.consumedetail_bill_v2

# —— story-web 三期：AI 创作生产线（详见 story-web/docs/ai/plan.md §3）——
# KIE.AI 一把 key 管 LLM + 图像 + 视频（从 story-web/.env.local 迁移）：
#   - LLM：POST {KIE_API_BASE}/gemini-3-flash/v1/chat/completions（OpenAI Chat Completions 兼容）
#   - 图像：nano-banana-pro
#   - 视频：wan/2-7-image-pro
# canvas v2 · 漫剧 Story LLM 系统 Provider（system:deepseek · OpenAI 兼容）
# DEEPSEEK_API_KEY=
# KIE_API_KEY=
# KIE_API_BASE=https://api.kie.ai
# 百炼 DashScope · 画布参考生视频（HappyHorse / 万相 R2V）；与 tool-web 同变量
# DASHSCOPE_API_KEY=
# 火山方舟 / 豆包（Gateway VOLCENGINE 凭证 · ark- API Key + IAM AK/SK，seed 脚本写入 Gateway）
# VOLCENGINE_API_KEY=
# VOLCENGINE_ACCESS_KEY=          # 或 VOLCENGINE_ACCESS_KEY_ID / VOLCENGINE_AK
# VOLCENGINE_SECRET_ACCESS_KEY=   # 或 VOLCENGINE_SECRET_KEY / VOLCENGINE_SK
# 可选：OpenAPI Host（默认 open.volcengineapi.com）
# VOLCENGINE_OPENAPI_HOST=open.volcengineapi.com
# KIE_CALLBACK_TOKEN=
# 可选：覆盖 LLM 端点（例如换自部署 OpenAI 兼容网关）
# STORY_AI_GEMINI_ENDPOINT=
# 公网回调基址。为空时不下发 callBackUrl，纯靠 poll worker（决议 §13.6）
# 生产示例：STORY_AI_PUBLIC_BASE=https://book.ai-code8.com
# STORY_AI_PUBLIC_BASE=
# 轮询/清理 worker 的 Bearer token（与腾讯云托管定时任务一致）
# STORY_AI_POLL_TOKEN=
# 上游并发软上限（可选，默认值见代码）
# STORY_AI_USER_INFLIGHT_MAX=50
# STORY_AI_KIE_MAX_CONCURRENCY=10
# STORY_AI_LLM_MAX_CONCURRENCY=5

# —— 统一积分计费 + 单会话（book-mall）——
# CREDIT_BILLING_OFF=1          # 设为 1 关闭新积分体系（回退旧钱包）
# SINGLE_SESSION_ENFORCE=1      # 新登录挤掉旧会话（本地测试建议开启）
# SINGLE_SESSION_RECHECK_SEC=60 # JWT 内 sv 重校验间隔（秒）
