# 复制为 .env.local 并填入真实值（勿提交密钥）
#
# Prisma CLI（migrate / build 中的 prisma migrate deploy）默认读取项目根目录的 .env，
# 不一定读取 .env.local。建议：内容与 .env.local 保持一致，再复制一份为 .env，
# 或在 shell 中导出 DATABASE_URL 后再执行构建。
#
# Neon：请从控制台「Connection」复制 Pooled（主机名通常含 -pooler）的连接串，并建议追加：
#   sslmode=require
#   pgbouncer=true          （Prisma 使用 Neon 事务池时推荐）
#   connect_timeout=30      （弱网 / 冷启动第一次连库多等几秒，减少误报）
# 勿使用 channel_binding=require（易与部分客户端不兼容）。
# 示例：
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=30

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# 逗号分隔管理员邮箱；执行 pnpm db:seed 时会把对应用户 role 设为 ADMIN（须已注册）
ADMIN_EMAILS=

# 切勿在真实生产开启。仅 Staging / 预演需要调用模拟支付 API 时设为 true（见 doc/process/mock-payment-checkout.md）
# ALLOW_MOCK_PAYMENT=true

# —— 独立工具站 SSO（黄金会员换票，详见 doc/tech/tools-sso-environment.md）——
# 工具站站点根 URL，无末尾 /
# TOOLS_PUBLIC_ORIGIN=https://tools.ai-code8.com
# 工具站服务端调用 exchange 时在 Authorization: Bearer … 使用（≥16 随机字符）
# TOOLS_SSO_SERVER_SECRET=
# JWT HS256 密钥，主站签发 / 工具站验签或仅用 introspect（≥16 随机字符）
# TOOLS_SSO_JWT_SECRET=
# 可选：授权码 TTL（秒）30–300，默认 90
# TOOLS_SSO_CODE_TTL_SECONDS=90
# 可选：JWT TTL（秒）120–7200，默认 600
# TOOLS_SSO_JWT_TTL_SECONDS=600
