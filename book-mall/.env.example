# 复制为 .env.local（勿提交仓库）。Prisma / Next 相关脚本默认通过 dotenv-cli 读取 .env.local。
# `pnpm dev` 时若未在本文件出现的键写在 .env.local，可沿用目录内 .env.development 的 localhost 默认项（.env.local 优先）。
#
# DATABASE_URL：务必使用 Neon 控制台里的 **Connection pooling** 字符串（主机多为 …pooler.neon.tech）。
# 推荐追加参数：sslmode=require&pgbouncer=true&connect_timeout=45（勿用 channel_binding=require）。
# 若 dev 控制台反复出现 prisma:error … connection Closed，多半是误用了「直连 / unpooled」或本地 TCP 被远端回收。
# 若出现「Timed out fetching a new connection from the connection pool」，可在 URL 末尾追加
# &pool_timeout=30（秒）略拉长取连接等待；根因多为并行请求过多或误用非 pooler 连接串。
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_EP_POOLER.neon.tech:5432/neondb?sslmode=require&pgbouncer=true&connect_timeout=45

# 本地开发（默认）
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# 生产示例（云托管控制台 / deploy/tencent/book-mall.env；勿提交真实密钥）：
# NEXTAUTH_URL=https://book.ai-code8.com
# TOOLS_PUBLIC_ORIGIN=https://tool.ai-code8.com
# 若控制台暂时仍填云托管默认 URL，可单独设签发用自定义域（须与浏览器打开工具站一致）：
# TOOLS_SSO_ISSUE_ORIGIN=https://tool.ai-code8.com

ADMIN_EMAILS=

# 可选：Google 登录（需同时配置以下三项；前台才显示「Google」按钮）
# NEXT_PUBLIC_AUTH_GOOGLE=1
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# —— 工具站 SSO（TOOLS_SSO_* 须与 tool-web/.env.local 完全一致）——
TOOLS_PUBLIC_ORIGIN=http://localhost:3001
TOOLS_SSO_SERVER_SECRET=
TOOLS_SSO_JWT_SECRET=

# 可选
# TOOLS_SSO_CODE_TTL_SECONDS=90
# TOOLS_SSO_JWT_TTL_SECONDS=600
# TOOLS_SSO_RELAX_MEMBERSHIP=1
# TOOLS_DIAGNOSTICS=1
# ALLOW_MOCK_PAYMENT=true

# —— OSS（与 tool-web 一致；删除图片/视频库记录时会尝试 deleteObject）——
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_REGION=oss-cn-guangzhou
# OSS_ENDPOINT=
# OSS_PUBLIC_URL_BASE=

# 详见 doc/tech/tools-sso-environment.md、仓库根目录 deploy.md

# —— finance-web 跨源拉取明细（可选）——
# 个人中心「费用与明细」外链（须与 finance-web 部署根地址一致；与 tool-web 同变量名）
# NEXT_PUBLIC_FINANCE_WEB_ORIGIN=http://localhost:3002
# 允许的来源，逗号分隔；需与 finance-web 浏览器 Origin 一致。
# FINANCE_WEB_ORIGINS=http://localhost:3002

# story-web（npm run dev -p 3003）：漫剧个人空间 CORS
# NEXT_PUBLIC_STORY_WEB_ORIGIN=http://localhost:3003
# STORY_WEB_ORIGINS=http://localhost:3003

# canvas-web（npm run dev -p 3004）：AI 海报画布 CORS
# NEXT_PUBLIC_CANVAS_WEB_ORIGIN=http://localhost:3004
# CANVAS_WEB_ORIGINS=http://localhost:3004
# CANVAS_CORS_IN_APP=1
# 可选：单画布并发上限（默认 5）；单用户进行中任务上限（默认 50）
# CANVAS_PROJECT_INFLIGHT_MAX=0
# 单画布并发任务上限；0 或不设 = 不限制；设正整数则启用（旧默认曾为 5）
# CANVAS_AI_USER_INFLIGHT_MAX=50
# canvas v2 · 用户 Provider API Key 加密密钥（base64 编码 32 字节）
# 生成：openssl rand -base64 32
# CANVAS_SECRET_KEY=
# 腾讯混元生3D（三视图引擎 · 系统 Provider system:hunyuan-3d）
# 专业版 Key（api.ai3d.cloud.tencent.com · OpenAI 兼容）
# HUNYUAN_3D_API_KEY=
# 极速版 / 普通版 · 官方 API（ai3d.tencentcloudapi.com · TC3 签名）
# HUNYUAN_TC_SECRET_ID=
# HUNYUAN_TC_SECRET_KEY=
# HUNYUAN_TC_REGION=ap-guangzhou
# 极速版 · TokenHub（可选，与官方 API 不是同一套凭证）
# HUNYUAN_TOKENHUB_API_KEY=
# HUNYUAN_3D_API_BASE=https://api.ai3d.cloud.tencent.com
# 仅开发：允许用 ?devUserId=<User.id> 代替 Cookie（勿在生产开启）
# FINANCE_ALLOW_DEV_USER_QUERY=1

# —— 云账单 CSV 导入（pnpm billing:import-cloud-csv）——
# BILLING_IMPORT_PRICING_TEMPLATE=aliyun.consumedetail_bill_v2

# —— story-web 三期：AI 创作生产线（详见 story-web/docs/ai/plan.md §3）——
# KIE.AI 一把 key 管 LLM + 图像 + 视频（从 story-web/.env.local 迁移）：
#   - LLM：POST {KIE_API_BASE}/gemini-3-flash/v1/chat/completions（OpenAI Chat Completions 兼容）
#   - 图像：nano-banana-pro
#   - 视频：wan/2-7-image-pro
# canvas v2 · 漫剧 Story LLM 系统 Provider（system:deepseek · OpenAI 兼容）
# DEEPSEEK_API_KEY=
# KIE_API_KEY=
# KIE_API_BASE=https://api.kie.ai
# KIE_CALLBACK_TOKEN=
# 可选：覆盖 LLM 端点（例如换自部署 OpenAI 兼容网关）
# STORY_AI_GEMINI_ENDPOINT=
# 公网回调基址。为空时不下发 callBackUrl，纯靠 poll worker（决议 §13.6）
# 生产示例：STORY_AI_PUBLIC_BASE=https://book.ai-code8.com
# STORY_AI_PUBLIC_BASE=
# 轮询/清理 worker 的 Bearer token（与腾讯云托管定时任务一致）
# STORY_AI_POLL_TOKEN=
# 上游并发软上限（可选，默认值见代码）
# STORY_AI_USER_INFLIGHT_MAX=50
# STORY_AI_KIE_MAX_CONCURRENCY=10
# STORY_AI_LLM_MAX_CONCURRENCY=5
