// AI Mall — PostgreSQL（生产：腾讯云 RDS `tool_mall`；本地详见 DATABASE_URL）
// 产品规则见 doc/product/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

// —— NextAuth 适配模型 ——
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  /// 邮箱密码注册时使用；OAuth 用户可为空
  passwordHash   String?
  role           UserRole  @default(USER)

  accounts                     Account[]
  sessions                     Session[]
  wallet                       Wallet?
  subscriptions                Subscription[]
  orders                       Order[]
  walletRefundRequests         WalletRefundRequest[]
  subscriptionRefundRequests   SubscriptionRefundRequest[]
  ssoAuthorizationCodes        SsoAuthorizationCode[]
  toolUsageEvents              ToolUsageEvent[]
  aiFitCustomModels            AiFitCustomModel[]
  aiFitGarmentUploads          AiFitGarmentUpload[]
  aiFitClosetItems             AiFitClosetItem[]
  textToImageLibraryItems      TextToImageLibraryItem[]
  imageToVideoLibraryItems     ImageToVideoLibraryItem[]
  courseLessonProgress         CourseLessonProgress[]
  userProductSubscriptions     UserProductSubscription[]
  userRechargeCoupons          UserRechargeCoupon[]
  toolBillingDetailLines       ToolBillingDetailLine[]
  cloudAccountBindings         CloudAccountBinding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// 课程课时学习进度（与 Product.slug 知识型课程关联）
model CourseLessonProgress {
  id          String    @id @default(cuid())
  userId      String
  courseSlug  String
  lessonIndex Int
  watchedSec  Int       @default(0)
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([userId, courseSlug, lessonIndex])
  @@index([userId, courseSlug])
}

/// AI 试衣：用户自定义模特（全身照等为 Data URL / base64 文本存库）
model AiFitCustomModel {
  id    String @id @default(cuid())
  userId String
  name  String
  style String @default("")
  height String @default("")
  weight String @default("")
  body  String @default("")
  bust  String?
  waist String?
  hips  String?
  /// data:image/jpeg|png|webp;base64,...
  imageDataUrl String @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

enum AiFitGarmentSlot {
  TOP
  BOTTOM
  ONE_PIECE
}

/// AI 试衣：用户上传的服装图（base64 Data URL）
model AiFitGarmentUpload {
  id     String           @id @default(cuid())
  userId String
  slot   AiFitGarmentSlot
  /// data:image/...;base64,...
  imageDataUrl String @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

enum AiFitClosetGarmentMode {
  TWO_PIECE
  ONE_PIECE
}

/// AI 试衣：用户「我的衣柜」收藏的成片（OSS 公网 URL）
model AiFitClosetItem {
  id     String @id @default(cuid())
  userId String

  /// 试衣成片 https URL（百炼/OSS）
  imageUrl String @db.Text

  /// 生成时所选搭配模式
  garmentMode AiFitClosetGarmentMode

  /// 生成上下文（用于「再试一次」/审计），均为 https URL
  personImageUrl   String? @db.Text
  topGarmentUrl    String? @db.Text
  bottomGarmentUrl String? @db.Text

  /// 用户备注（可选，<=120 字）
  note String?

  /// 关联百炼 task_id（可选，便于回溯）
  taskId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// 文生图：用户「我的图片库」收藏的成片（https 公网 URL）
model TextToImageLibraryItem {
  id       String @id @default(cuid())
  userId   String

  imageUrl String @db.Text
  /// 生成时的提示词摘要（可选）
  prompt   String? @db.VarChar(2000)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// 图生/参考/文生视频：用户「我的视频库」收藏的成片（OSS 长期链 + 建议保留期限）
model ImageToVideoLibraryItem {
  id     String @id @default(cuid())
  userId String

  videoUrl   String  @db.Text
  prompt     String? @db.Text
  /// i2v | t2v | ref
  mode       String
  resolution String
  durationSec Int
  seed      String?
  modelLabel String?

  /// 建议清理时间不早于该时刻（默认创建 +7 天）；管理员可提前删除
  retainUntil DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([retainUntil])
}

/// 工具站访问 / 调用打点（审计与后续扣费扩展）；写入方为主站 API，身份以工具 JWT 的 sub 为准。
model ToolUsageEvent {
  id        String   @id @default(cuid())
  userId    String
  /// 业务约定的工具键，如 fitting-room、home
  toolKey   String
  /// page_view、invoke 等
  action    String   @default("page_view")
  meta      Json?
  /// 单次消耗点数（1 点 = ¥0.01）；可与 PlatformConfig.toolInvokePerCallPoints 对齐，或由调用方传入
  costPoints Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  toolBillingDetailLines ToolBillingDetailLine[]

  @@index([userId, toolKey, createdAt])
  @@index([toolKey, createdAt])
}

/// 财务：与云 consumedetailbillv2 等颗粒度对齐的明细行（cloudRow 存云侧原文；对内计价快照存 internal*；计价逻辑按 pricingTemplateKey 选模板）。
enum ToolBillingDetailSource {
  CLOUD_CSV_IMPORT
  TOOL_USAGE_GENERATED
}

model ToolBillingDetailLine {
  id     String @id @default(cuid())
  userId String
  /// 可选：与单次工具扣费事件关联，便于对账
  toolUsageEventId String?

  source   ToolBillingDetailSource @default(CLOUD_CSV_IMPORT)
  /// 云 CSV 列名 -> 字符串值（完整明细快照）
  cloudRow Json

  /// 入库或回填时固化的对内计价快照（便于按行追溯当时口径；勿在读接口依赖实时重算）
  internalCloudCostUnitYuan Decimal?  @db.Decimal(24, 10)
  internalRetailMultiplier  Decimal?  @db.Decimal(12, 6)
  internalOurUnitYuan       Decimal?  @db.Decimal(24, 10)
  internalFormulaText       String?   @db.Text
  internalChargedPoints     Int?
  internalYuanReference     Decimal?  @db.Decimal(24, 10)
  internalCapturedAt      DateTime?

  /// 对内计价所用模板（多云厂商扩展）；如 aliyun.consumedetail_bill_v2
  pricingTemplateKey        String    @default("aliyun.consumedetail_bill_v2")

  createdAt DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolUsageEvent ToolUsageEvent? @relation(fields: [toolUsageEventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([toolUsageEventId])
}

/// 工具应用按次计费单价（点，1 点 = ¥0.01）；生效区间内匹配 toolKey + action，优先精确 action，其次 action 为空表示该工具通配。
model ToolBillablePrice {
  id            String    @id @default(cuid())
  toolKey       String
  /// 例如 try_on、invoke；null 表示未限定 action（慎用）
  action        String?
  pricePoints   Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  active        Boolean   @default(true)
  note          String?
  /// 方案 A 展示用：与工具站 catalog 一致的参考模型 id
  schemeARefModelKey String?
  /// 方案 A：后台维护的单位成本（元，税前/官网口径与价目库一致）；与 schemeAAdminRetailMultiplier 相乘生成标价
  schemeAUnitCostYuan          Float?
  /// 方案 A：后台为该行指定的零售系数 M（生成 pricePoints；工具站 SSO 按 toolKey+schemeARefModelKey 读此行）
  schemeAAdminRetailMultiplier Float?

  /// v002：回链到 PricingSourceLine.modelKey（云厂商成本真源），便于 pricing:verify 漂移检查
  cloudModelKey   String?
  /// v002：回链到 PricingSourceLine.tierRaw（规格/档位，如 "1080P"、"720P"、"-"）
  cloudTierRaw    String?
  /// v002：回链到 PricingSourceLine.billingKind（计费维度），用于选 internal.tool_usage_* 模板
  cloudBillingKind PricingBillingKind?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([toolKey, effectiveFrom])
  @@index([cloudModelKey, cloudTierRaw, cloudBillingKind])
}

/// 工具站左侧菜单项是否在导航中展示（由主站后台维护）；navKey 与 tool-web `config/nav-tools` 约定一致。
model ToolNavVisibility {
  navKey    String   @id
  label     String
  visible   Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

// —— 平台配置（单行 default）——
model PlatformConfig {
  id                   String   @id @default("default")
  /// 高级/按量服务最低可用余额（点），默认 2000 = ¥20
  minBalanceLinePoints  Int      @default(2000)
  balanceWarnHighPoints Int      @default(5000)
  balanceWarnMidPoints  Int      @default(3000)
  /// LLM：每千 token 计价（点），0 表示未启用/占位
  llmInputPer1kTokensPoints  Int @default(0)
  llmOutputPer1kTokensPoints Int @default(0)
  /// 高阶工具：单次调用默认扣费（点）
  toolInvokePerCallPoints    Int @default(0)
  /// 异常消耗：超过近均值的百分比即告警，如 300=3 倍
  usageAnomalyRatioPercent  Int @default(300)
  updatedAt            DateTime @updatedAt
}

/// 价目导入版本（成本唯一源头；current 仅一条 isCurrent=true）。
model PricingSourceVersion {
  id               String    @id @default(cuid())
  kind             String
  sourceSha256     String
  regionScope      String    @default("china_mainland")
  label            String?
  importedAt       DateTime  @default(now())
  importedByUserId String?
  parseWarnings    Json?
  rowCount         Int       @default(0)
  isCurrent        Boolean   @default(false)

  lines       PricingSourceLine[]
  changesFrom PricingLineChangeEvent[] @relation("PricingChangeFrom")
  changesTo   PricingLineChangeEvent[] @relation("PricingChangeTo")

  @@index([isCurrent])
  @@index([importedAt])
}

enum PricingBillingKind {
  TOKEN_IN_OUT
  OUTPUT_IMAGE
  COST_PER_IMAGE
  VIDEO_MODEL_SPEC
}

/// 单条成本行（某版本快照内唯一 fingerprint）。
model PricingSourceLine {
  id                   String             @id @default(cuid())
  versionId            String
  sectionH2            String             @default("")
  sectionH3            String             @default("")
  modelKey             String
  modelLabelRaw        String             @db.Text
  tierRaw              String             @default("")
  billingKind          PricingBillingKind @default(TOKEN_IN_OUT)
  inputYuanPerMillion  Float?
  outputYuanPerMillion Float?
  costJson             Json?
  fingerprint          String
  sourceLine           Int?

  /// v002：有效成本系数（如 0.8 表示 8 折促销）；解析器暂不写，由对账脚本回填
  effectiveDiscount   Float?
  /// v002：促销说明（来源/期限/规则），由对账脚本从 CSV 的 `优惠详情` 推断
  effectivePromoNote  String? @db.Text
  /// v002：促销快照采集时间
  effectiveCapturedAt DateTime?

  version PricingSourceVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, fingerprint])
  @@index([versionId, modelKey])
}

/// v002 P5：云厂商「资源购买账号 ID」与平台 User 的绑定（解决 CSV 上传时归属判定）。
model CloudAccountBinding {
  id              String   @id @default(cuid())
  /// 云厂商账号 ID（如阿里云 `资源购买账号ID = 1068915519298264`）；规范化为大小写不敏感唯一
  cloudAccountId  String   @unique
  /// 云厂商账号名（仅展示，如 `viclau620`）
  cloudAccountName String?
  /// 绑定的平台 User.id
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

/// v002 P5：一次「上传 CSV → 自动对账」的批次记录。
model BillingReconciliationRun {
  id              String   @id @default(cuid())
  /// 上传 CSV 的 SHA-256，防重复
  csvSha256       String
  /// 原始文件名（便于审计）
  csvFilename     String
  /// CSV 内涉及的账单月份（多月情形以逗号分隔）
  monthsCovered   String
  /// 触发此批次的管理员 User.id
  importedByUserId String
  /// 自动统计摘要（JSON）：内/外行数、内/外总金额、差额、verdict、unbound 账号列表等
  summary         Json
  /// 状态：READY（已生成报告）、CLAWED_BACK（已补扣过任意行）、ARCHIVED（管理员归档）
  status          String   @default("READY")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           BillingReconciliationLine[]

  @@unique([csvSha256])
  @@index([createdAt])
  @@index([importedByUserId])
}

/// v002 P5：一次对账批次下的「单用户 × 单(模型/计费维度)」一行；补扣由本表的 `clawback*` 字段记录。
model BillingReconciliationLine {
  id            String   @id @default(cuid())
  runId         String
  run           BillingReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  /// 平台用户 id（CSV 行通过 CloudAccountBinding 映射来）；可为 null 表示未绑定云账号
  userId        String?
  /// 云账号 id（便于显示 unbound 行）
  cloudAccountId String?
  modelKey      String
  billingKind   String
  internalCount Int      @default(0)
  internalYuan  Decimal  @default(0) @db.Decimal(18, 4)
  cloudCount    Int      @default(0)
  cloudPayableYuan Decimal @default(0) @db.Decimal(18, 4)
  diffYuan      Decimal  @default(0) @db.Decimal(18, 4)
  /// BOTH / INTERNAL_ONLY / CLOUD_ONLY / UNBOUND
  matchKind     String

  /// 已补扣的金额（点）；null 表示未补扣
  clawbackPoints Int?
  /// 补扣对应的 WalletEntry.id；用于审计
  clawbackEntryId String?
  clawedAt      DateTime?

  createdAt     DateTime @default(now())

  @@index([runId, userId])
  @@index([runId, matchKind])
}

/// 版本间 diff（历史审计）。
model PricingLineChangeEvent {
  id            String             @id @default(cuid())
  fromVersionId String?
  toVersionId   String
  modelKey      String
  tierRaw       String             @default("")
  billingKind   PricingBillingKind
  changeType    String
  oldSnapshot   Json?
  newSnapshot   Json?
  createdAt     DateTime           @default(now())

  fromVersion PricingSourceVersion? @relation("PricingChangeFrom", fields: [fromVersionId], references: [id], onDelete: SetNull)
  toVersion   PricingSourceVersion  @relation("PricingChangeTo", fields: [toVersionId], references: [id], onDelete: Cascade)

  @@index([toVersionId])
  @@index([modelKey])
}

// —— 钱包 ——
model Wallet {
  id            String @id @default(cuid())
  userId        String @unique
  balancePoints  Int    @default(0)
  frozenPoints   Int    @default(0)
  currency      String @default("CNY")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries WalletEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WalletEntryType {
  RECHARGE
  CONSUME
  REFUND
  ADJUST
}

model WalletEntry {
  id               String          @id @default(cuid())
  walletId         String
  type             WalletEntryType
  /// 入为正、出为负（点）
  amountPoints      Int
  balanceAfterPoints Int
  idempotencyKey   String?         @unique
  description      String?
  orderId          String?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
}

// —— 订阅 ——
enum SubscriptionInterval {
  MONTH
  YEAR
}

model SubscriptionPlan {
  id         String               @id @default(cuid())
  slug       String               @unique
  name       String
  interval   SubscriptionInterval
  pricePoints Int
  active     Boolean              @default(true)
  /// 工具站侧栏分组 navKey 白名单；空数组表示订阅期内可使用「当前套件」内全部工具分组。
  toolsNavAllowlist String[] @default([])

  /// 价格不可直接修改：发布新版本时旧 plan 归档（archivedAt + active=false），
  /// 主 slug 让位给新 plan，旧 slug 改为 `${slug}__v${ts}`；老 Subscription.planId
  /// 仍指向归档 plan，可完整溯源当时订阅价/名称/工具范围。
  archivedAt   DateTime?
  parentPlanId String?
  parent       SubscriptionPlan?  @relation("PlanLineage", fields: [parentPlanId], references: [id], onDelete: SetNull)
  successors   SubscriptionPlan[] @relation("PlanLineage")

  subscriptions Subscription[]

  @@index([active, archivedAt])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, status])
}

// —— 订单（含模拟支付）——
enum OrderType {
  SUBSCRIPTION
  WALLET_TOPUP
  PRODUCT_SUBSCRIPTION
}

enum OrderStatus {
  PENDING
  AWAITING_MOCK_CONFIRM
  PAID
  FAILED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  type        OrderType
  status      OrderStatus @default(PENDING)
  amountPoints Int
  currency    String      @default("CNY")
  /// 订阅目标 planSlug、充值档位等
  meta        Json?
  /// 订阅类订单完成提现处理后标记
  refundedAt  DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  paidAt DateTime?

  rechargeCouponRedemption UserRechargeCoupon?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

// —— 充值优惠：模板（平台配置）+ 用户领取的优惠券（核销后绑定 Order）——
enum RechargeCouponStatus {
  UNUSED
  REDEEMED
  EXPIRED
}

model RechargePromoTemplate {
  id    String @id @default(cuid())
  slug  String @unique
  title String
  /// 核销时要求实付点与此完全一致（如 10000 = ¥100 档）
  paidAmountPoints Int
  bonusPoints      Int
  active           Boolean  @default(true)
  claimableFrom    DateTime
  claimableTo      DateTime
  /// 领取后多少天内有效，逾期 UNUSED → EXPIRED
  validDaysAfterClaim Int @default(7)
  maxClaimsPerUser    Int @default(1)
  sortOrder           Int @default(0)
  note                String? @db.Text

  coupons UserRechargeCoupon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserRechargeCoupon {
  id         String               @id @default(cuid())
  userId     String
  templateId String
  status     RechargeCouponStatus @default(UNUSED)
  /// 领取时快照，避免改模板影响已发票
  paidAmountPointsSnap Int
  bonusPointsSnap      Int
  titleSnap            String
  templateSlugSnap     String
  claimedAt            DateTime
  expiresAt            DateTime
  redeemedAt           DateTime?
  orderId              String? @unique

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  template RechargePromoTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  order    Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, templateId])
  @@index([expiresAt])
}

// —— 提现审核（产品 6.3 / 5.3）——
enum RefundRequestStatus {
  PENDING
  COMPLETED
  REJECTED
}

/// 余额提现：用户申请 → 后台核算应扣未扣 → 扣减后入账（流水记提现）
model WalletRefundRequest {
  id        String @id @default(cuid())
  userId    String
  status    RefundRequestStatus @default(PENDING)
  /// 申请提现金额（点），null 表示按「可提现余额」由后台核算
  requestedAmountPoints Int?
  /// 应扣未扣（点），管理员核准
  pendingSettlementPoints Int @default(0)
  /// 实际从钱包扣减并记为提现的金额（点）
  refundAmountPoints      Int?
  userNote               String?
  adminNote              String?
  decidedAt              DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([status, createdAt])
}

/// 订阅订单提现审核（政策独立于余额提现）
model SubscriptionRefundRequest {
  id         String @id @default(cuid())
  userId     String
  orderId    String?
  subscriptionId String?
  status     RefundRequestStatus @default(PENDING)
  userReason String?
  adminNote  String?
  decidedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([status, createdAt])
}

// —— 产品（5.1 知识型 / 工具型）——
enum ProductKind {
  KNOWLEDGE
  TOOL
}

enum ProductTier {
  BASIC
  ADVANCED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductDescriptionFormat {
  PLAIN
  MARKDOWN
}

enum UserProductSubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

/// 用户按「单品」订阅的课程或工具（与会员计划订阅并行）
model UserProductSubscription {
  id                 String                        @id @default(cuid())
  userId             String
  productId          String
  status             UserProductSubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime                      @default(now())
  currentPeriodEnd   DateTime

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId, status])
}

/// 分类：两大品类下支持子分类（parentId 为空为顶级）
model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  kind      ProductKind
  parentId  String?
  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  ProductCategory[] @relation("CategoryHierarchy")
  products  Product[]
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId, kind])
}

model Product {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  /// 一句话概述（首页推荐/列表）
  summary         String
  /// 详情
  description     String        @db.Text
  /// 详情展示：纯文本（保留换行）或 Markdown
  descriptionFormat ProductDescriptionFormat @default(PLAIN)
  /// 知识型：课程内容等（富文本简化存文本）
  courseContent   String?       @db.Text
  kind            ProductKind
  tier            ProductTier
  coverImageUrl   String
  status          ProductStatus @default(DRAFT)
  /// 仍上架展示，但前台不可新订（已订用户保留权益）；不等同于归档下架
  catalogUnavailable Boolean    @default(false)
  /// 工具型：对应工具站套件 navKey（如 fitting-room）；用于单品工具订阅授权
  toolNavKey      String?
  /// 首页推荐
  featuredHome    Boolean       @default(false)
  featuredSort    Int           @default(0)
  /// 工具型：权限说明、大模型计费说明
  toolPermissions String?       @db.Text
  meteringNote    String?       @db.Text

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  userProductSubscriptions UserProductSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, status])
  @@index([featuredHome, status, featuredSort])
}

/// 独立工具站 SSO：一次性授权码（换取短时 JWT）
model SsoAuthorizationCode {
  id         String    @id @default(cuid())
  code       String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([expiresAt])
}
