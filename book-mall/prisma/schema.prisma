// AI Mall — PostgreSQL（生产：腾讯云 RDS `tool_mall`；本地详见 DATABASE_URL）
// 产品规则见 doc/product/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

// —— NextAuth 适配模型 ——
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  /// 邮箱密码注册时使用；OAuth 用户可为空
  passwordHash   String?
  role           UserRole  @default(USER)

  accounts                     Account[]
  sessions                     Session[]
  wallet                       Wallet?
  subscriptions                Subscription[]
  orders                       Order[]
  walletRefundRequests         WalletRefundRequest[]
  subscriptionRefundRequests   SubscriptionRefundRequest[]
  ssoAuthorizationCodes        SsoAuthorizationCode[]
  toolUsageEvents              ToolUsageEvent[]
  aiFitCustomModels            AiFitCustomModel[]
  aiFitGarmentUploads          AiFitGarmentUpload[]
  aiFitClosetItems             AiFitClosetItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// AI 试衣：用户自定义模特（全身照等为 Data URL / base64 文本存库）
model AiFitCustomModel {
  id    String @id @default(cuid())
  userId String
  name  String
  style String @default("")
  height String @default("")
  weight String @default("")
  body  String @default("")
  bust  String?
  waist String?
  hips  String?
  /// data:image/jpeg|png|webp;base64,...
  imageDataUrl String @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

enum AiFitGarmentSlot {
  TOP
  BOTTOM
  ONE_PIECE
}

/// AI 试衣：用户上传的服装图（base64 Data URL）
model AiFitGarmentUpload {
  id     String           @id @default(cuid())
  userId String
  slot   AiFitGarmentSlot
  /// data:image/...;base64,...
  imageDataUrl String @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

enum AiFitClosetGarmentMode {
  TWO_PIECE
  ONE_PIECE
}

/// AI 试衣：用户「我的衣柜」收藏的成片（OSS 公网 URL）
model AiFitClosetItem {
  id     String @id @default(cuid())
  userId String

  /// 试衣成片 https URL（百炼/OSS）
  imageUrl String @db.Text

  /// 生成时所选搭配模式
  garmentMode AiFitClosetGarmentMode

  /// 生成上下文（用于「再试一次」/审计），均为 https URL
  personImageUrl   String? @db.Text
  topGarmentUrl    String? @db.Text
  bottomGarmentUrl String? @db.Text

  /// 用户备注（可选，<=120 字）
  note String?

  /// 关联百炼 task_id（可选，便于回溯）
  taskId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// 工具站访问 / 调用打点（审计与后续扣费扩展）；写入方为主站 API，身份以工具 JWT 的 sub 为准。
model ToolUsageEvent {
  id        String   @id @default(cuid())
  userId    String
  /// 业务约定的工具键，如 fitting-room、home
  toolKey   String
  /// page_view、invoke 等
  action    String   @default("page_view")
  meta      Json?
  /// 单次消耗（分）；可与 PlatformConfig.toolInvokePerCallMinor 对齐，或由调用方传入
  costMinor Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, toolKey, createdAt])
  @@index([toolKey, createdAt])
}

/// 工具应用按次计费单价（分）；生效区间内匹配 toolKey + action，优先精确 action，其次 action 为空表示该工具通配。
model ToolBillablePrice {
  id            String    @id @default(cuid())
  toolKey       String
  /// 例如 try_on、invoke；null 表示未限定 action（慎用）
  action        String?
  priceMinor    Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  active        Boolean   @default(true)
  note          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([toolKey, effectiveFrom])
}

/// 工具站左侧菜单项是否在导航中展示（由主站后台维护）；navKey 与 tool-web `config/nav-tools` 约定一致。
model ToolNavVisibility {
  navKey    String   @id
  label     String
  visible   Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

// —— 平台配置（单行 default）——
model PlatformConfig {
  id                   String   @id @default("default")
  /// 高级/按量服务最低可用余额，默认 2000=20 元（分）
  minBalanceLineMinor  Int      @default(2000)
  balanceWarnHighMinor Int      @default(5000)
  balanceWarnMidMinor  Int      @default(3000)
  /// LLM：每千 token 计价（分），0 表示未启用/占位
  llmInputPer1kTokensMinor  Int @default(0)
  llmOutputPer1kTokensMinor Int @default(0)
  /// 高阶工具：单次调用默认扣费（分）
  toolInvokePerCallMinor    Int @default(0)
  /// 异常消耗：超过近均值的百分比即告警，如 300=3 倍
  usageAnomalyRatioPercent  Int @default(300)
  updatedAt            DateTime @updatedAt
}

// —— 钱包 ——
model Wallet {
  id            String @id @default(cuid())
  userId        String @unique
  balanceMinor  Int    @default(0)
  frozenMinor   Int    @default(0)
  currency      String @default("CNY")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries WalletEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WalletEntryType {
  RECHARGE
  CONSUME
  REFUND
  ADJUST
}

model WalletEntry {
  id               String          @id @default(cuid())
  walletId         String
  type             WalletEntryType
  /// 入为正、出为负（分）
  amountMinor      Int
  balanceAfterMinor Int
  idempotencyKey   String?         @unique
  description      String?
  orderId          String?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
}

// —— 订阅 ——
enum SubscriptionInterval {
  MONTH
  YEAR
}

model SubscriptionPlan {
  id         String               @id @default(cuid())
  slug       String               @unique
  name       String
  interval   SubscriptionInterval
  priceMinor Int
  active     Boolean              @default(true)

  subscriptions Subscription[]
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, status])
}

// —— 订单（含模拟支付）——
enum OrderType {
  SUBSCRIPTION
  WALLET_TOPUP
}

enum OrderStatus {
  PENDING
  AWAITING_MOCK_CONFIRM
  PAID
  FAILED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  type        OrderType
  status      OrderStatus @default(PENDING)
  amountMinor Int
  currency    String      @default("CNY")
  /// 订阅目标 planSlug、充值档位等
  meta        Json?
  /// 订阅类订单完成退款处理后标记
  refundedAt  DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

// —— 退款审核（产品 6.3 / 5.3）——
enum RefundRequestStatus {
  PENDING
  COMPLETED
  REJECTED
}

/// 余额退款：用户申请 → 后台核算应扣未扣 → 扣减后退还（流水入账）
model WalletRefundRequest {
  id        String @id @default(cuid())
  userId    String
  status    RefundRequestStatus @default(PENDING)
  /// 申请退还金额（分），null 表示按「可退余额」由后台核算
  requestedAmountMinor Int?
  /// 应扣未扣（分），管理员核准
  pendingSettlementMinor Int @default(0)
  /// 实际从钱包扣减并记为退款的金额（分）
  refundAmountMinor      Int?
  userNote               String?
  adminNote              String?
  decidedAt              DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([status, createdAt])
}

/// 订阅订单退款审核（政策独立于余额退款）
model SubscriptionRefundRequest {
  id         String @id @default(cuid())
  userId     String
  orderId    String?
  subscriptionId String?
  status     RefundRequestStatus @default(PENDING)
  userReason String?
  adminNote  String?
  decidedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([status, createdAt])
}

// —— 产品（5.1 知识型 / 工具型）——
enum ProductKind {
  KNOWLEDGE
  TOOL
}

enum ProductTier {
  BASIC
  ADVANCED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// 分类：两大品类下支持子分类（parentId 为空为顶级）
model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  kind      ProductKind
  parentId  String?
  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  ProductCategory[] @relation("CategoryHierarchy")
  products  Product[]
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId, kind])
}

model Product {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  /// 一句话概述（首页推荐/列表）
  summary         String
  /// 详情
  description     String        @db.Text
  /// 知识型：课程内容等（富文本简化存文本）
  courseContent   String?       @db.Text
  kind            ProductKind
  tier            ProductTier
  /// 标价（分）
  priceMinor      Int           @default(0)
  coverImageUrl   String
  status          ProductStatus @default(DRAFT)
  /// 首页推荐
  featuredHome    Boolean       @default(false)
  featuredSort    Int           @default(0)
  /// 工具型：权限说明、大模型计费说明
  toolPermissions String?       @db.Text
  meteringNote    String?       @db.Text

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, status])
  @@index([featuredHome, status, featuredSort])
}

/// 独立工具站 SSO：一次性授权码（换取短时 JWT）
model SsoAuthorizationCode {
  id         String    @id @default(cuid())
  code       String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([expiresAt])
}
