// AI Mall — PostgreSQL（生产：腾讯云 RDS `tool_mall`；本地详见 DATABASE_URL）
// 产品规则见 doc/product/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER // 普通用户
  ADMIN // 兼容旧值：等同运营+（历史管理员）
  OPERATIONS // 运营：套餐/调价提案/用量看板，不看厂商成本
  FINANCE // 财务：厂商成本、反向验算、毛利、对账、审批
  SUPER_ADMIN // 超级管理员：全部权限 + 终审
}

// —— NextAuth 适配模型 ——
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  /// 邮箱密码注册时使用；OAuth 用户可为空
  passwordHash  String?
  role          UserRole  @default(USER)

  accounts                         Account[]
  sessions                         Session[]
  wallet                           Wallet?
  subscriptions                    Subscription[]
  orders                           Order[]
  paymentCheckouts                 PaymentCheckout[]
  paymentCheckoutsConfirmed        PaymentCheckout[] @relation("PaymentCheckoutConfirmedBy")
  paymentEvents                    PaymentEvent[]
  walletRefundRequests             WalletRefundRequest[]
  subscriptionRefundRequests       SubscriptionRefundRequest[]
  ssoAuthorizationCodes            SsoAuthorizationCode[]
  toolUsageEvents                  ToolUsageEvent[]
  aiFitCustomModels                AiFitCustomModel[]
  aiFitGarmentUploads              AiFitGarmentUpload[]
  aiFitClosetItems                 AiFitClosetItem[]
  textToImageLibraryItems          TextToImageLibraryItem[]
  imageToVideoLibraryItems         ImageToVideoLibraryItem[]
  courseLessonProgress             CourseLessonProgress[]
  userProductSubscriptions         UserProductSubscription[]
  userRechargeCoupons              UserRechargeCoupon[]
  toolBillingDetailLines           ToolBillingDetailLine[]
  cloudAccountBindings             CloudAccountBinding[]
  walletHolds                      WalletHold[]
  toolModelUsageCounters           ToolModelUsageCounter[]
  storySpace                       StorySpace?
  storyProjects                    StoryProject[]
  canvasProjects                   CanvasProject[]
  canvasTemplates                  CanvasTemplate[]
  canvasCharacters                 CanvasCharacter[]
  storyProCharacterAssets          StoryProCharacterAsset[]
  storyProSceneAssets              StoryProSceneAsset[]
  storyProStyleProfiles            StoryProStyleProfile[]
  storyProCharacterAudioAssets     StoryProCharacterAudioAsset[]
  storyProScriptAssistantHistories StoryProScriptAssistantHistory[]
  canvasProviders                  CanvasProvider[]
  canvasPromptTemplates            CanvasPromptTemplate[]
  toolServicePeriods               UserToolServicePeriod[]
  ecomAssets                       EcomAsset[]
  ecomStoryboardProjects           EcomStoryboardProject[]
  mediaRenderJobs                  MediaRenderJob[]
  mediaStorageGrants               UserMediaStorageGrant[]

  /// 多租户：主空间（个人租户）。回填脚本为每个用户建 PERSONAL 租户后写入。
  primaryTenantId      String?
  ownedTenants         Tenant[]       @relation("TenantOwner")
  tenantMemberships    TenantMember[]
  tenantInvitesCreated TenantInvite[] @relation("TenantInviteCreator")

  /// 单会话挤下线：每次成功登录自增；JWT 内 ver 与此不一致即失效（里程碑 7 启用）
  sessionVersion Int @default(0)

  /// 电商工具箱计费：默认 BYOK 月费；PLATFORM_METERED 为代付按次扣点（由 billingPersona 推导，用户不可改）
  ecomBillingMode EcomBillingMode @default(BYOK_SERVICE_FEE)

  /// 计费身份：注册时选定，互斥（平台代付 vs 自带 Key）
  billingPersona         BillingPersona  @default(PLATFORM_CREDIT)
  billingPersonaLockedAt DateTime?

  /// Canvas 经 Gateway 代理：关联的 sk-gw API Key（验证后仅存 id，不存明文）
  gatewayApiKeyId       String?        @unique
  gatewayApiKeyLinkedAt DateTime?
  linkedGatewayApiKey   GatewayApiKey? @relation(fields: [gatewayApiKeyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// 按用户 + 模型 + 账期累计用量（用于云厂商阶梯价，如 aitryon-refiner 按生成张数分档）。
model ToolModelUsageCounter {
  id        String   @id @default(cuid())
  userId    String
  /// 与 ToolBillablePrice.schemeARefModelKey / 云 API model 一致，如 aitryon-refiner
  modelKey  String
  /// 账期键，UTC 自然月 YYYY-MM（与需求 v1.0.0 约定一致）
  periodKey String
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, modelKey, periodKey])
  @@index([userId, modelKey])
}

/// 课程课时学习进度（与 Product.slug 知识型课程关联）
model CourseLessonProgress {
  id          String    @id @default(cuid())
  userId      String
  courseSlug  String
  lessonIndex Int
  watchedSec  Int       @default(0)
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([userId, courseSlug, lessonIndex])
  @@index([userId, courseSlug])
}

/// AI 试衣：用户自定义模特（全身照等为 Data URL / base64 文本存库）
model AiFitCustomModel {
  id           String  @id @default(cuid())
  userId       String
  name         String
  style        String  @default("")
  height       String  @default("")
  weight       String  @default("")
  body         String  @default("")
  bust         String?
  waist        String?
  hips         String?
  /// data:image/jpeg|png|webp;base64,...
  imageDataUrl String  @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

enum AiFitGarmentSlot {
  TOP
  BOTTOM
  ONE_PIECE
}

/// AI 试衣：用户上传的服装图（base64 Data URL）
model AiFitGarmentUpload {
  id           String           @id @default(cuid())
  userId       String
  slot         AiFitGarmentSlot
  /// data:image/...;base64,...
  imageDataUrl String           @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

enum AiFitClosetGarmentMode {
  TWO_PIECE
  ONE_PIECE
}

/// AI 试衣：用户「我的衣柜」收藏的成片（OSS 公网 URL）
model AiFitClosetItem {
  id     String @id @default(cuid())
  userId String

  /// 试衣成片 https URL（百炼/OSS）
  imageUrl String @db.Text

  /// 生成时所选搭配模式
  garmentMode AiFitClosetGarmentMode

  /// 生成上下文（用于「再试一次」/审计），均为 https URL
  personImageUrl   String? @db.Text
  topGarmentUrl    String? @db.Text
  bottomGarmentUrl String? @db.Text

  /// 用户备注（可选，<=120 字）
  note String?

  /// 关联百炼 task_id（可选，便于回溯）
  taskId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// 文生图：用户「我的图片库」收藏的成片（https 公网 URL）
model TextToImageLibraryItem {
  id     String @id @default(cuid())
  userId String

  imageUrl String  @db.Text
  /// 生成时的提示词摘要（可选）
  prompt   String? @db.VarChar(2000)

  /// 资产共享（租户体系）：归属租户 / 创建成员 / 可见域
  tenantId    String?
  ownerUserId String?
  visibility  AssetVisibility @default(PRIVATE)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([tenantId, visibility, createdAt])
}

/// 图生/参考/文生视频：用户「我的视频库」收藏的成片（OSS 长期链 + 建议保留期限）
model ImageToVideoLibraryItem {
  id     String @id @default(cuid())
  userId String

  videoUrl    String  @db.Text
  prompt      String? @db.Text
  /// i2v | t2v | ref
  mode        String
  resolution  String
  durationSec Int
  seed        String?
  modelLabel  String?

  /// 建议清理时间不早于该时刻（默认创建 +7 天）；管理员可提前删除
  retainUntil DateTime

  /// 资产共享（租户体系）：归属租户 / 创建成员 / 可见域
  tenantId    String?
  ownerUserId String?
  visibility  AssetVisibility @default(PRIVATE)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([retainUntil])
  @@index([tenantId, visibility, createdAt])
}

/// 工具站访问 / 调用打点（审计与后续扣费扩展）；写入方为主站 API，身份以工具 JWT 的 sub 为准。
model ToolUsageEvent {
  id             String   @id @default(cuid())
  userId         String
  /// 业务约定的工具键，如 fitting-room、home
  toolKey        String
  /// page_view、invoke 等
  action         String   @default("page_view")
  meta           Json?
  /// 单次消耗点数（1 点 = ¥0.01）；可与 PlatformConfig.toolInvokePerCallPoints 对齐，或由调用方传入
  costPoints     Int?
  /// 视频类工具实际计费秒数（向上取整后 + minBilledVideoSec 兜底；用于审计与按秒计费溯源）
  billedVideoSec Int?
  /// 关联的预占用 hold（若使用 reserve→settle 流程上报）
  walletHoldId   String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  toolBillingDetailLines ToolBillingDetailLine[]
  walletHold             WalletHold?             @relation("HoldSettledByEvent", fields: [walletHoldId], references: [id], onDelete: SetNull)

  @@index([userId, toolKey, createdAt])
  @@index([toolKey, createdAt])
}

/// 财务：与云 consumedetailbillv2 等颗粒度对齐的明细行（cloudRow 存云侧原文；对内计价快照存 internal*；计价逻辑按 pricingTemplateKey 选模板）。
enum ToolBillingDetailSource {
  CLOUD_CSV_IMPORT
  TOOL_USAGE_GENERATED
}

model ToolBillingDetailLine {
  id               String  @id @default(cuid())
  userId           String
  /// 可选：与单次工具扣费事件关联，便于对账
  toolUsageEventId String?

  source   ToolBillingDetailSource @default(CLOUD_CSV_IMPORT)
  /// v005：完整账单明细快照（与云 CSV 同字段名 + 平台 8 列）；所有"对内计价"信息（云成本单价、
  /// 系数 M、我方单价、本行扣点）都在此 JSON 内的「定价信息/官网目录价 + 平台/系数(M) + 平台/定价
  /// + 平台/扣点」键里。删除了 v004 的 7 列 Decimal 镜像（internalCloudCostUnitYuan 等），单一数据源。
  cloudRow Json

  /// 对内计价所用模板（多云厂商扩展）；如 aliyun.consumedetail_bill_v2
  pricingTemplateKey String @default("aliyun.consumedetail_bill_v2")

  createdAt DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolUsageEvent ToolUsageEvent? @relation(fields: [toolUsageEventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([toolUsageEventId])
}

/// 工具套件按月技术服务费定价（点/月）；与 toolNavKey 一一对应。
model ToolServiceFeePlan {
  id               String   @id @default(cuid())
  toolNavKey       String   @unique
  label            String
  monthlyFeePoints Int      @default(0)
  active           Boolean  @default(true)
  sortOrder        Int      @default(0)
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  periods UserToolServicePeriod[]
}

enum ToolServicePeriodStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

/// 用户某工具套件的有效技术服务费周期（开通/续订后写入）。
model UserToolServicePeriod {
  id                String                  @id @default(cuid())
  userId            String
  toolNavKey        String
  planId            String?
  periodStart       DateTime
  periodEnd         DateTime
  status            ToolServicePeriodStatus @default(ACTIVE)
  lastChargedPoints Int?
  walletEntryId     String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  user User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan ToolServiceFeePlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([userId, toolNavKey, status])
  @@index([userId, periodEnd])
  @@index([toolNavKey, periodEnd])
}

/// 电商工具箱用户资产（OSS URL + 元数据）
model EcomAsset {
  id           String  @id @default(cuid())
  userId       String
  module       String
  kind         String
  title        String?
  prompt       String? @db.Text
  ossUrl       String
  thumbnailUrl String?
  meta         Json?

  /// 资产共享（租户体系）：归属租户 / 创建成员 / 可见域
  tenantId    String?
  ownerUserId String?
  visibility  AssetVisibility @default(PRIVATE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, module, createdAt])
  @@index([tenantId, visibility, createdAt])
}

/// 电商工具箱 · 微剧情分镜故事版项目（聊天、HTML/PNG、视频）
model EcomStoryboardProject {
  id           String  @id @default(cuid())
  userId       String
  title        String?
  module       String  @default("storyboard-micro-drama")
  status       String  @default("draft")
  brief        Json?
  settings     Json?
  references   Json?
  chatHistory  Json?
  sheet        Json?
  sheetPngUrl  String?
  sheetHtmlUrl String?
  videoAssetId String?
  meta         Json?

  /// 资产共享（租户体系）：归属租户 / 创建成员 / 可见域
  tenantId    String?
  ownerUserId String?
  visibility  AssetVisibility @default(PRIVATE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, module, updatedAt])
  @@index([tenantId, visibility, updatedAt])
}

enum MediaRenderJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  EXPIRED
}

enum MediaRenderStorageTier {
  ephemeral
  pinned
}

enum MediaRenderSourceApp {
  canvas
  ecom
  api
}

/// 云端自动剪辑任务（xfade 成片，默认 7 天 ephemeral）
model MediaRenderJob {
  id           String                 @id @default(cuid())
  userId       String
  sourceApp    MediaRenderSourceApp
  sourceRef    Json?
  timelineJson Json
  profileJson  Json
  status        MediaRenderJobStatus   @default(PENDING)
  progress      Int                    @default(0)
  progressLabel String?                @db.VarChar(120)
  resultOssUrl String?
  errorMessage String?                @db.Text
  bytesOut     Int?
  expiresAt    DateTime
  storageTier  MediaRenderStorageTier @default(ephemeral)
  pinnedAt     DateTime?
  createdAt    DateTime               @default(now())
  completedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([expiresAt, storageTier, status])
}

/// 用户媒体容量包（延期保留成片）
model UserMediaStorageGrant {
  id         String   @id @default(cuid())
  userId     String
  bytesQuota BigInt
  bytesUsed  BigInt   @default(0)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

/// 工具站左侧菜单项是否在导航中展示（由主站后台维护）；navKey 与 tool-web `config/nav-tools` 约定一致。
model ToolNavVisibility {
  navKey    String   @id
  label     String
  visible   Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

// —— 平台配置（单行 default）——
model PlatformConfig {
  id                         String   @id @default("default")
  /// 高级/按量服务最低可用余额（点），默认 2000 = ¥20
  minBalanceLinePoints       Int      @default(2000)
  balanceWarnHighPoints      Int      @default(5000)
  balanceWarnMidPoints       Int      @default(3000)
  /// LLM：每千 token 计价（点），0 表示未启用/占位
  llmInputPer1kTokensPoints  Int      @default(0)
  llmOutputPer1kTokensPoints Int      @default(0)
  /// 高阶工具：单次调用默认扣费（点）
  toolInvokePerCallPoints    Int      @default(0)
  /// 异常消耗：超过近均值的百分比即告警，如 300=3 倍
  usageAnomalyRatioPercent   Int      @default(300)
  /// v003：视频按秒计费的最低计费秒数兜底（不足按此秒计；建议 5）
  minBilledVideoSec          Int      @default(5)
  /// v003：图片按张计费的最低张数兜底
  minBilledImageCount        Int      @default(1)
  /// v003：单次调用的最低扣点（避免 0 元/极低费用）
  minChargePointsPerInvoke   Int      @default(1)
  /// v003：WalletHold（预占用）默认 TTL（分钟）；超时未 settle 由 cron 自动 RELEASED→EXPIRED
  /// v005（2026-05-18）：默认从 30 → 10。视频任务实际生成大多 < 5 分钟；
  /// 留 10 分钟兜底足够，避免长尾未 settle 的 hold 长期占住用户余额。
  walletHoldDefaultTtlMin    Int      @default(10)
  updatedAt                  DateTime @updatedAt
}

/// 价目导入版本（成本唯一源头；current 仅一条 isCurrent=true）。
model PricingSourceVersion {
  id               String   @id @default(cuid())
  kind             String
  sourceSha256     String
  regionScope      String   @default("china_mainland")
  label            String?
  importedAt       DateTime @default(now())
  importedByUserId String?
  parseWarnings    Json?
  rowCount         Int      @default(0)
  isCurrent        Boolean  @default(false)

  lines       PricingSourceLine[]
  changesFrom PricingLineChangeEvent[] @relation("PricingChangeFrom")
  changesTo   PricingLineChangeEvent[] @relation("PricingChangeTo")

  @@index([isCurrent])
  @@index([importedAt])
}

enum PricingBillingKind {
  TOKEN_IN_OUT
  OUTPUT_IMAGE
  COST_PER_IMAGE
  VIDEO_MODEL_SPEC
}

/// 单条成本行（某版本快照内唯一 fingerprint）。
model PricingSourceLine {
  id                   String             @id @default(cuid())
  versionId            String
  sectionH2            String             @default("")
  sectionH3            String             @default("")
  modelKey             String
  modelLabelRaw        String             @db.Text
  tierRaw              String             @default("")
  billingKind          PricingBillingKind @default(TOKEN_IN_OUT)
  inputYuanPerMillion  Float?
  outputYuanPerMillion Float?
  costJson             Json?
  fingerprint          String
  sourceLine           Int?

  /// v002：有效成本系数（如 0.8 表示 8 折促销）；解析器暂不写，由对账脚本回填
  effectiveDiscount   Float?
  /// v002：促销说明（来源/期限/规则），由对账脚本从 CSV 的 `优惠详情` 推断
  effectivePromoNote  String?   @db.Text
  /// v002：促销快照采集时间
  effectiveCapturedAt DateTime?

  version PricingSourceVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, fingerprint])
  @@index([versionId, modelKey])
}

/// v002 P5：云厂商「资源购买账号 ID」与平台 User 的绑定（解决 CSV 上传时归属判定）。
model CloudAccountBinding {
  id               String   @id @default(cuid())
  /// 云厂商账号 ID（如阿里云 `资源购买账号ID = 1068915519298264`）；规范化为大小写不敏感唯一
  cloudAccountId   String   @unique
  /// 云厂商账号名（仅展示，如 `viclau620`）
  cloudAccountName String?
  /// 绑定的平台 User.id
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

/// v002 P5：一次「上传 CSV → 自动对账」的批次记录。
model BillingReconciliationRun {
  id               String   @id @default(cuid())
  /// 上传 CSV 的 SHA-256，防重复
  csvSha256        String
  /// 原始文件名（便于审计）
  csvFilename      String
  /// CSV 内涉及的账单月份（多月情形以逗号分隔）
  monthsCovered    String
  /// 触发此批次的管理员 User.id
  importedByUserId String
  /// 自动统计摘要（JSON）：内/外行数、内/外总金额、差额、verdict、unbound 账号列表等
  summary          Json
  /// 状态：READY（已生成报告）、CLAWED_BACK（已补扣过任意行）、ARCHIVED（管理员归档）
  status           String   @default("READY")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lines BillingReconciliationLine[]

  @@unique([csvSha256])
  @@index([createdAt])
  @@index([importedByUserId])
}

/// v002 P5：一次对账批次下的「单用户 × 单(模型/计费维度)」一行；补扣由本表的 `clawback*` 字段记录。
model BillingReconciliationLine {
  id               String                   @id @default(cuid())
  runId            String
  run              BillingReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  /// 平台用户 id（CSV 行通过 CloudAccountBinding 映射来）；可为 null 表示未绑定云账号
  userId           String?
  /// 云账号 id（便于显示 unbound 行）
  cloudAccountId   String?
  modelKey         String
  billingKind      String
  internalCount    Int                      @default(0)
  internalYuan     Decimal                  @default(0) @db.Decimal(18, 4)
  cloudCount       Int                      @default(0)
  cloudPayableYuan Decimal                  @default(0) @db.Decimal(18, 4)
  diffYuan         Decimal                  @default(0) @db.Decimal(18, 4)
  /// BOTH / INTERNAL_ONLY / CLOUD_ONLY / UNBOUND
  matchKind        String

  /// 已补扣的金额（点）；null 表示未补扣
  clawbackPoints  Int?
  /// 补扣对应的 WalletEntry.id；用于审计
  clawbackEntryId String?
  clawedAt        DateTime?

  createdAt DateTime @default(now())

  @@index([runId, userId])
  @@index([runId, matchKind])
}

/// 版本间 diff（历史审计）。
model PricingLineChangeEvent {
  id            String             @id @default(cuid())
  fromVersionId String?
  toVersionId   String
  modelKey      String
  tierRaw       String             @default("")
  billingKind   PricingBillingKind
  changeType    String
  oldSnapshot   Json?
  newSnapshot   Json?
  createdAt     DateTime           @default(now())

  fromVersion PricingSourceVersion? @relation("PricingChangeFrom", fields: [fromVersionId], references: [id], onDelete: SetNull)
  toVersion   PricingSourceVersion  @relation("PricingChangeTo", fields: [toVersionId], references: [id], onDelete: Cascade)

  @@index([toVersionId])
  @@index([modelKey])
}

// —— 钱包 ——
model Wallet {
  id            String @id @default(cuid())
  userId        String @unique
  balancePoints Int    @default(0)
  frozenPoints  Int    @default(0)
  currency      String @default("CNY")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries WalletEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WalletEntryType {
  RECHARGE
  CONSUME
  REFUND
  ADJUST
}

model WalletEntry {
  id                 String          @id @default(cuid())
  walletId           String
  type               WalletEntryType
  /// 入为正、出为负（点）
  amountPoints       Int
  balanceAfterPoints Int
  idempotencyKey     String?         @unique
  description        String?
  orderId            String?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
}

/// v003：钱包预占用（reservation/hold）状态。
/// HELD：reserve 已扣"可用余额"但未真实扣 balancePoints；
/// SETTLED：settle 时按真实用量扣 balancePoints 并写 ToolUsageEvent；
/// RELEASED：调用方明确释放（生成失败/取消）；
/// EXPIRED：超过 expiresAt 由 cron 自动 RELEASED 的别名（保留枚举便于查询）。
enum WalletHoldStatus {
  HELD
  SETTLED
  RELEASED
  EXPIRED
}

/// v003：钱包预占用记录——按秒计费场景下"先估上限、后按真实用量结算"。
/// 可用余额 = balancePoints − Σ(WalletHold WHERE status=HELD).reservedPoints。
model WalletHold {
  id                  String           @id @default(cuid())
  userId              String
  toolKey             String
  action              String?
  /// 预占点数（1 点 = ¥0.01）；以"最大可能用量 × 系数 × 1.2 安全边际"估算
  reservedPoints      Int
  status              WalletHoldStatus @default(HELD)
  /// 任务幂等键（典型：云厂商 taskId）；与 (userId) 共同唯一，避免同任务重复 reserve
  taskKey             String?
  /// 提示性元信息（estimated durationSec / modelKey / resolution 等）
  meta                Json?
  /// 自动释放时间（默认 PlatformConfig.walletHoldDefaultTtlMin）
  expiresAt           DateTime
  /// SETTLED 时落本次实际扣点；与 ToolUsageEvent.costPoints 一致
  settledChargePoints Int?
  /// SETTLED 时回填，便于审计与流水回查
  settledUsageEventId String?
  /// RELEASED/EXPIRED 时的原因，便于运维查问
  releaseReason       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  settledUsageEvents ToolUsageEvent[] @relation("HoldSettledByEvent")

  @@unique([userId, taskKey])
  @@index([userId, status])
  @@index([status, expiresAt])
}

/// v003 模型校准：标准模型（canonical）目录。
/// 一个 canonicalKey 在内部所有列展示与对账中作为"模型"主键；通过 ModelAlias 挂接云厂商/工具站/价目表等各自的字串。
model ModelCatalog {
  id             String             @id @default(cuid())
  /// 标准模型 key（人可读，跨表用作 group 键）；如 `happyhorse-1.0-i2v`
  canonicalKey   String             @unique
  /// 显示名（含规格/中文）；如 `HappyHorse 图生视频 1.0`
  displayName    String
  /// 厂商（aliyun / tencent / huawei / volcengine / ...）
  vendor         String
  /// 默认档位（1080P/720P/-）；对账可二级聚合
  defaultTierRaw String?
  /// 计费维度（与 PricingSourceLine.billingKind 对齐）
  billingKind    PricingBillingKind
  /// 显示单位标签（"元/秒"/"元/张"/"元/百万 tokens"）
  unitLabel      String
  active         Boolean            @default(true)
  note           String?            @db.Text

  /// Gateway 统一注册表（2026-06）
  requestKind       GatewayRequestKind?
  role              CanvasModelRole?
  mediaKind         ModelMediaKind?
  appTags           String[]           @default([])
  gatewayPublished  Boolean            @default(false)

  /// v006（2026-05-17）：云厂商账单 5 列的"本 catalog 主映射"——配合费用明细展示。
  /// 一个 canonical 配 1 个 primary vendor 映射；未来若同 canonical 跨多家云需要并存，
  /// 再 split 出独立的 `ModelCatalogVendorBinding(1:N)` 表，把这 5 列迁过去（schema 演进路径已规划）。
  ///
  /// 「厂商产品/产品名称」如 "大模型服务平台百炼"
  vendorProductName      String?
  /// 「厂商产品/商品Code」如 "sfm_inference_public_cn"
  vendorCommodityCode    String?
  /// 「厂商产品/商品名称」如 "百炼大模型推理"
  vendorCommodityName    String?
  /// 「厂商产品/计费项Code」如 "image_number"
  vendorBillableItemCode String?
  /// 「厂商产品/计费项名称」如 "大模型图片生成量"
  vendorBillableItemName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aliases ModelAlias[]
  routes  GatewayModelRoute[]

  @@index([vendor, active])
  @@index([gatewayPublished, active])
}

enum ModelAliasSource {
  VENDOR_COMMODITY_CODE
  VENDOR_BILLABLE_ITEM
  VENDOR_RESOURCE_SPEC
  VENDOR_PRODUCT_NAME
  INTERNAL_TOOLKEY
  INTERNAL_ACTION
  INTERNAL_SCHEME_A_MODEL
  PRICE_MD_LABEL
  MANUAL_OTHER
}

enum AliasConfidence {
  HIGH
  MEDIUM
  LOW
  MANUAL
}

/// v003 模型校准：单条别名（来自云 CSV / 工具站 toolKey / price.md / 手动）。
/// 自动建议时 catalogId 可空（pending review）；人工"接受建议"后绑定到具体 ModelCatalog。
model ModelAlias {
  id        String        @id @default(cuid())
  catalogId String?
  catalog   ModelCatalog? @relation(fields: [catalogId], references: [id], onDelete: SetNull)

  source      ModelAliasSource
  aliasValue  String
  tierRawHint String?
  confidence  AliasConfidence  @default(LOW)
  /// 自动匹配算法名（exact/prefix/fuzzy/manual）
  matchedBy   String?
  /// 评估证据样本（如来自哪行 CSV、命中哪几条规则）
  evidence    Json?
  active      Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, aliasValue])
  @@index([catalogId, source])
  @@index([catalogId])
}

// —— 订阅 ——
enum SubscriptionInterval {
  MONTH
  YEAR
}

model SubscriptionPlan {
  id                String               @id @default(cuid())
  slug              String               @unique
  name              String
  interval          SubscriptionInterval
  pricePoints       Int
  active            Boolean              @default(true)
  /// 工具站侧栏分组 navKey 白名单；空数组表示订阅期内可使用「当前套件」内全部工具分组。
  toolsNavAllowlist String[]             @default([])

  /// 价格不可直接修改：发布新版本时旧 plan 归档（archivedAt + active=false），
  /// 主 slug 让位给新 plan，旧 slug 改为 `${slug}__v${ts}`；老 Subscription.planId
  /// 仍指向归档 plan，可完整溯源当时订阅价/名称/工具范围。
  archivedAt   DateTime?
  parentPlanId String?
  parent       SubscriptionPlan?  @relation("PlanLineage", fields: [parentPlanId], references: [id], onDelete: SetNull)
  successors   SubscriptionPlan[] @relation("PlanLineage")

  subscriptions Subscription[]

  @@index([active, archivedAt])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, status])
}

// —— 订单（含模拟支付）——
enum OrderType {
  SUBSCRIPTION
  WALLET_TOPUP
  PRODUCT_SUBSCRIPTION
  MEMBERSHIP
  CREDIT_TOPUP
  BYOK_SERVICE_FEE
}

enum PaymentProductKind {
  MEMBERSHIP_PERSONAL
  MEMBERSHIP_TEAM
  BYOK_PERSONAL
  BYOK_TEAM
  CREDIT_TOPUP
}

enum PaymentChannel {
  WECHAT_PERSONAL
  MOCK
}

enum PaymentCheckoutStatus {
  PENDING
  AWAITING_CONFIRM
  PAID
  EXPIRED
  CANCELLED
}

enum PaymentConfirmMode {
  ADMIN_MANUAL
  ADMIN_INSTANT
}

enum PaymentEventAction {
  CREATE
  USER_SUBMITTED
  ADMIN_CONFIRM
  ADMIN_INSTANT
  EXPIRE
  CANCEL
}

enum OrderStatus {
  PENDING
  AWAITING_MOCK_CONFIRM
  PAID
  FAILED
  CANCELLED
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  type         OrderType
  status       OrderStatus @default(PENDING)
  amountPoints Int
  amountYuan   Decimal?    @db.Decimal(12, 2)
  currency     String      @default("CNY")
  /// 订阅目标 planSlug、充值档位等
  meta         Json?
  /// 订阅类订单完成提现处理后标记
  refundedAt   DateTime?
  paymentCheckoutId String? @unique

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentCheckout PaymentCheckout? @relation(fields: [paymentCheckoutId], references: [id], onDelete: SetNull)
  paidAt          DateTime?

  rechargeCouponRedemption UserRechargeCoupon?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model PaymentCheckout {
  id                String                @id @default(cuid())
  outTradeNo        String                @unique
  remarkCode        String
  userId            String
  productKind       PaymentProductKind
  productSnapshot   Json
  amountYuan        Decimal               @db.Decimal(12, 2)
  channel           PaymentChannel        @default(WECHAT_PERSONAL)
  status            PaymentCheckoutStatus @default(PENDING)
  confirmMode       PaymentConfirmMode?
  confirmedByUserId String?
  adminNote         String?               @db.Text
  paidAt            DateTime?
  expiresAt         DateTime

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  confirmedBy User?          @relation("PaymentCheckoutConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  order       Order?
  events      PaymentEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([remarkCode, status])
  @@index([status, createdAt])
}

model PaymentEvent {
  id          String             @id @default(cuid())
  checkoutId  String
  actorUserId String?
  action      PaymentEventAction
  payload     Json?

  checkout PaymentCheckout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  actor    User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([checkoutId, createdAt])
}

// —— 充值优惠：模板（平台配置）+ 用户领取的优惠券（核销后绑定 Order）——
enum RechargeCouponStatus {
  UNUSED
  REDEEMED
  EXPIRED
}

model RechargePromoTemplate {
  id                  String   @id @default(cuid())
  slug                String   @unique
  title               String
  /// 核销时要求实付点与此完全一致（如 10000 = ¥100 档）
  paidAmountPoints    Int
  bonusPoints         Int
  active              Boolean  @default(true)
  claimableFrom       DateTime
  claimableTo         DateTime
  /// 领取后多少天内有效，逾期 UNUSED → EXPIRED
  validDaysAfterClaim Int      @default(7)
  maxClaimsPerUser    Int      @default(1)
  sortOrder           Int      @default(0)
  note                String?  @db.Text

  coupons UserRechargeCoupon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserRechargeCoupon {
  id                   String               @id @default(cuid())
  userId               String
  templateId           String
  status               RechargeCouponStatus @default(UNUSED)
  /// 领取时快照，避免改模板影响已发票
  paidAmountPointsSnap Int
  bonusPointsSnap      Int
  titleSnap            String
  templateSlugSnap     String
  claimedAt            DateTime
  expiresAt            DateTime
  redeemedAt           DateTime?
  orderId              String?              @unique

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  template RechargePromoTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  order    Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, templateId])
  @@index([expiresAt])
}

// —— 提现审核（产品 6.3 / 5.3）——
enum RefundRequestStatus {
  PENDING
  COMPLETED
  REJECTED
}

/// 余额提现：用户申请 → 后台核算应扣未扣 → 扣减后入账（流水记提现）
model WalletRefundRequest {
  id                      String              @id @default(cuid())
  userId                  String
  status                  RefundRequestStatus @default(PENDING)
  /// 申请提现金额（点），null 表示按「可提现余额」由后台核算
  requestedAmountPoints   Int?
  /// 应扣未扣（点），管理员核准
  pendingSettlementPoints Int                 @default(0)
  /// 实际从钱包扣减并记为提现的金额（点）
  refundAmountPoints      Int?
  userNote                String?
  adminNote               String?
  decidedAt               DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([status, createdAt])
}

/// 订阅订单提现审核（政策独立于余额提现）
model SubscriptionRefundRequest {
  id             String              @id @default(cuid())
  userId         String
  orderId        String?
  subscriptionId String?
  status         RefundRequestStatus @default(PENDING)
  userReason     String?
  adminNote      String?
  decidedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([status, createdAt])
}

// —— 产品（5.1 知识型 / 工具型）——
enum ProductKind {
  KNOWLEDGE
  TOOL
}

enum ProductTier {
  BASIC
  ADVANCED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductDescriptionFormat {
  PLAIN
  MARKDOWN
}

enum UserProductSubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

/// 用户按「单品」订阅的课程或工具（与会员计划订阅并行）
model UserProductSubscription {
  id                 String                        @id @default(cuid())
  userId             String
  productId          String
  status             UserProductSubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime                      @default(now())
  currentPeriodEnd   DateTime

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId, status])
}

/// 分类：两大品类下支持子分类（parentId 为空为顶级）
model ProductCategory {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  kind      ProductKind
  parentId  String?
  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  ProductCategory[] @relation("CategoryHierarchy")
  products  Product[]
  sortOrder Int               @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId, kind])
}

model Product {
  id                 String                   @id @default(cuid())
  title              String
  slug               String                   @unique
  /// 一句话概述（首页推荐/列表）
  summary            String
  /// 详情
  description        String                   @db.Text
  /// 详情展示：纯文本（保留换行）或 Markdown
  descriptionFormat  ProductDescriptionFormat @default(PLAIN)
  /// 知识型：课程内容等（富文本简化存文本）
  courseContent      String?                  @db.Text
  kind               ProductKind
  tier               ProductTier
  coverImageUrl      String
  status             ProductStatus            @default(DRAFT)
  /// 仍上架展示，但前台不可新订（已订用户保留权益）；不等同于归档下架
  catalogUnavailable Boolean                  @default(false)
  /// 工具型：对应工具站套件 navKey（如 fitting-room）；用于单品工具订阅授权
  toolNavKey         String?
  /// 首页推荐
  featuredHome       Boolean                  @default(false)
  featuredSort       Int                      @default(0)
  /// 工具型：权限说明、大模型计费说明
  toolPermissions    String?                  @db.Text
  meteringNote       String?                  @db.Text

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  userProductSubscriptions UserProductSubscription[]
  storySpaceAsPublished    StorySpace?               @relation("StorySpacePublishedProduct")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, status])
  @@index([featuredHome, status, featuredSort])
}

/// 独立工具站 SSO：一次性授权码（换取短时 JWT）
model SsoAuthorizationCode {
  id         String    @id @default(cuid())
  code       String    @unique
  userId     String
  /// Phase F：第三方 client_id（可选）
  clientId   String?
  expiresAt  DateTime
  consumedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@index([clientId])
}

/// Phase F：第三方 Platform SSO 客户端注册
model SsoClient {
  id             String   @id @default(cuid())
  clientId       String   @unique
  name           String
  /// 注册回调 URI 白名单（完整 URL，不含 query）
  redirectUris   String[]
  /// 允许访问的工具 navKey 子集；空 = 不额外限制（仍须用户自身服务期）
  allowedNavKeys String[] @default([])
  active         Boolean  @default(true)
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// —— story-web 漫剧个人空间 ——

enum StoryEngineRole {
  LLM
  IMAGE
  VIDEO
}

enum StorySpaceTemplateKey {
  CLASSIC_V1
}

enum StorySpacePublishStatus {
  DRAFT
  PUBLISHED
}

/// story-web 可选 AI 引擎模型目录（平台维护；用户空间内勾选主用模型）
model StoryEngineModel {
  id            String          @id @default(cuid())
  modelKey      String          @unique
  displayName   String
  vendor        String
  role          StoryEngineRole
  description   String?         @db.Text
  sortOrder     Int             @default(0)
  active        Boolean         @default(true)
  defaultParams Json?

  selections StorySpaceModelSelection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role, active, sortOrder])
}

/// 用户漫剧个人空间（一人一条；slug 对外访问）
model StorySpace {
  id                      String                  @id @default(cuid())
  userId                  String                  @unique
  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                    String                  @unique
  templateKey             StorySpaceTemplateKey   @default(CLASSIC_V1)
  title                   String
  tagline                 String
  subtitle                String                  @db.Text
  ownerDisplayName        String?
  featuredWorkTitle       String
  featuredWorkDescription String?
  featuredVideoUrl        String
  featuredVideoPosterUrl  String?
  publishStatus           StorySpacePublishStatus @default(DRAFT)
  publishedAt             DateTime?
  publishedProductId      String?                 @unique
  publishedProduct        Product?                @relation("StorySpacePublishedProduct", fields: [publishedProductId], references: [id], onDelete: SetNull)

  modelSelections StorySpaceModelSelection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publishStatus])
}

/// 空间内启用的引擎模型（每 role 可设 isPrimary）
model StorySpaceModelSelection {
  id            String           @id @default(cuid())
  storySpaceId  String
  storySpace    StorySpace       @relation(fields: [storySpaceId], references: [id], onDelete: Cascade)
  engineModelId String
  engineModel   StoryEngineModel @relation(fields: [engineModelId], references: [id], onDelete: Cascade)
  enabled       Boolean          @default(true)
  isPrimary     Boolean          @default(false)
  params        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storySpaceId, engineModelId])
  @@index([storySpaceId, enabled])
}

// —— story-web 三期：AI 创作生产线（项目 / 角色 / 分镜 / 任务 / OSS 清理队列） ——
// 详见 story-web/docs/ai/plan.md §2

enum StoryProjectAspect {
  RATIO_16_9
  RATIO_9_16
}

enum StoryProjectStatus {
  DRAFT
  INITIALIZING
  READY
  ARCHIVED
}

enum StoryGenerationKind {
  COVER_IMAGE
  CHARACTER_AVATAR
  FRAME_IMAGE
  FRAME_VIDEO
}

enum StoryGenerationStatus {
  PENDING
  SUBMITTED
  SUCCEEDED
  FAILED
  CANCELLED
}

/// 漫剧项目主表
model StoryProject {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String             @db.Text
  aspectRatio StoryProjectAspect
  /// 关联 story-web/src/shared/styles/index.json 的 id
  styleId     Int

  /// AI 一键初始化产出，初始为空字符串
  storyOutline String @default("") @db.Text

  /// 封面图 OSS 公网 URL；初始空
  coverImageUrl String  @default("")
  /// 当前封面任务 id（用于前端轮询/进度显示），仅引用不做 FK
  coverTaskId   String?

  status    StoryProjectStatus @default(DRAFT)
  /// 软删时间；查询默认过滤
  deletedAt DateTime?

  /// 资产共享（租户体系）：归属租户 / 创建成员 / 可见域
  tenantId    String?
  ownerUserId String?
  visibility  AssetVisibility @default(PRIVATE)

  characters   StoryCharacter[]
  frames       StoryStoryboardFrame[]
  tasks        StoryGenerationTask[]
  cleanupItems StoryOssCleanupQueue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, deletedAt, updatedAt])
  @@index([status])
  @@index([tenantId, visibility, updatedAt])
}

/// 项目角色
model StoryCharacter {
  id        String       @id @default(cuid())
  projectId String
  project   StoryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name         String
  role         String  @default("")
  description  String  @default("") @db.Text
  /// 角色外观提示词（仅外观/构图/白底，不含风格段；调用 KIE 时由后端按 styleId 实时拼接 [STYLE]）
  imagePrompt  String  @db.Text
  /// 角色头像 OSS 公网 URL；初始空
  avatarUrl    String  @default("")
  /// 当前头像任务 id；仅引用不做 FK
  avatarTaskId String?

  /// 同项目下排序
  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, sortOrder])
}

/// 分镜
model StoryStoryboardFrame {
  id        String       @id @default(cuid())
  projectId String
  project   StoryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 第几格（1-based）
  index            Int
  sceneText        String   @default("")
  sceneDescription String   @default("") @db.Text
  /// 该分镜涉及的角色 id 列表（StoryCharacter.id），按出场先后；删除角色时由服务层 array_remove
  characterIds     String[] @default([])

  /// 分镜图 prompt：角色描述 + 场景描述（不含风格，调用时拼装）
  imagePrompt String @db.Text
  /// 运镜 prompt（不含风格）
  videoPrompt String @db.Text

  /// 分镜图 OSS 公网 URL（初始空）
  imageUrl    String  @default("")
  imageTaskId String?

  /// 分镜视频 OSS 公网 URL（初始空）
  videoUrl    String  @default("")
  videoTaskId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, index])
  @@index([projectId])
}

/// 统一的 KIE/AI 生成任务表（覆盖封面/角色/分镜图/分镜视频四类）
model StoryGenerationTask {
  id          String       @id @default(cuid())
  projectId   String
  project     StoryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// 关联的目标实体（按 kind 二选一）
  characterId String?
  frameId     String?

  kind   StoryGenerationKind
  status StoryGenerationStatus @default(PENDING)

  /// KIE 模型名：nano-banana-pro / wan/2-7-image-pro
  model         String
  /// KIE 返回的 taskId（提交后填入，用于回调/轮询匹配）
  kieTaskId     String? @unique
  /// Gateway 请求日志 id（经 Gateway 代理时写入）
  gatewayLogId  String?
  /// 提交给 KIE 的完整 input（便于排查与重放，含已拼接的风格段）
  inputPayload  Json
  /// KIE 回调或 recordInfo 原始响应（最近一次）
  resultPayload Json?
  /// KIE 返回的临时 URL（OSS 上传失败时保留作为人工补救入口）
  ephemeralUrl  String?
  /// 落 OSS 后的稳定 URL（成功时回写到目标实体相同字段）
  ossUrl        String?

  failCode    String?
  failMessage String?

  submittedAt  DateTime?
  completedAt  DateTime?
  lastPolledAt DateTime?
  pollCount    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, submittedAt])
  @@index([projectId, kind])
  @@index([characterId])
  @@index([frameId])
}

/// OSS 异步清理队列：删除 / 重新生成时旧的稳定 URL 入队，由 cron worker 调 deleteManagedOssObjectByUrl 清理
model StoryOssCleanupQueue {
  id          String        @id @default(cuid())
  /// 来源上下文（仅排查用，例 "project_delete:cuid_xxx" / "regenerate_cover:cuid"）
  source      String?
  /// 关联项目（项目硬删后允许保留为 null）
  projectId   String?
  project     StoryProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// 待清理的 OSS 公网 URL
  ossUrl      String
  /// 不要在该时间之前清理（用于"先生成新图再删旧图"的窗口期）
  notBefore   DateTime      @default(now())
  /// 已尝试次数；>=3 视为失败，等人工排查
  attempts    Int           @default(0)
  lastTriedAt DateTime?
  lastError   String?
  /// 完成时间；非空即视为已清理（保留作为审计）
  doneAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doneAt, notBefore])
  @@index([projectId])
}

// —— canvas-web AI 海报画布 ——
// 详见 canvas-web/docs/plan.md

enum CanvasModelRole {
  IMAGE
  VIDEO
  LLM
}

enum CanvasGenerationKind {
  IMAGE
  TEXT
}

enum CanvasGenerationStatus {
  PENDING
  SUBMITTED
  SUCCEEDED
  FAILED
  CANCELLED
}

/// 用户级 Provider 类型；canvas v2
enum CanvasProviderKind {
  KIE
  ALI_BAILIAN
  OPENAI_COMPAT
  GEMINI_NATIVE
  HUNYUAN_3D
}

/// 画布可选 AI 引擎模型目录（user/admin 可在 canvas-web /models 配置；首批种子三条）
model CanvasEngineModel {
  id            String          @id @default(cuid())
  modelKey      String          @unique
  displayName   String
  vendor        String
  role          CanvasModelRole
  description   String?         @db.Text
  sortOrder     Int             @default(0)
  active        Boolean         @default(true)
  defaultParams Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role, active, sortOrder])
}

/// 画布项目（一份完整的节点工作流 + 视图）
model CanvasProject {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String @default("") @db.Text

  /// 整张画布 JSON：{ schemaVersion, nodes[], edges[], viewport }
  canvas       Json
  /// 缩略图（最近一张 OutputNode 输出）
  thumbnailUrl String @default("")

  deletedAt DateTime?

  /// 资产共享（租户体系）：归属租户 / 创建成员 / 可见域
  tenantId    String?
  ownerUserId String?
  visibility  AssetVisibility @default(PRIVATE)

  tasks        CanvasGenerationTask[]
  cleanupItems CanvasOssCleanupQueue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, deletedAt, updatedAt])
  @@index([tenantId, visibility, updatedAt])
}

/// 画布模板：系统模板（builtin=true 且 ownerUserId=null）+ 用户私有模板
model CanvasTemplate {
  id          String  @id @default(cuid())
  ownerUserId String?
  owner       User?   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  category  String
  name      String
  thumbnail String  @default("")
  /// 同 CanvasProject.canvas 结构
  canvas    Json
  builtin   Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId, sortOrder])
  @@index([builtin, sortOrder])
}

/// 用户保存的三视图角色（从三视图引擎生成后入库，可在画布快速插入图片节点）
model CanvasCharacter {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  imageUrl        String
  model           String?
  sourceTaskId    String?
  sourceProjectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

enum StoryProCharacterAssetRefKind {
  face
  full_body
  outfit
  three_view
}

/// 影视专业版 · 角色资产库（characterKey → 多图 ref）
model StoryProCharacterAsset {
  id           String                      @id @default(cuid())
  userId       String
  user         User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterKey String
  displayName  String
  projectId    String?
  locked       Boolean                     @default(false)
  version      Int                         @default(1)
  refs         StoryProCharacterAssetRef[]
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@unique([userId, characterKey, projectId])
  @@index([userId, updatedAt])
}

model StoryProCharacterAssetRef {
  id           String                        @id @default(cuid())
  assetId      String
  asset        StoryProCharacterAsset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  kind         StoryProCharacterAssetRefKind
  ossUrl       String
  sortOrder    Int                           @default(0)
  label        String?
  sourceTaskId String?
  createdAt    DateTime                      @default(now())

  @@index([assetId, sortOrder])
}

enum StoryProSceneAssetRefKind {
  establishing
  detail
  mood
}

/// 影视专业版 · 场景资产库（sceneKey → 多图 ref）
model StoryProSceneAsset {
  id          String                  @id @default(cuid())
  userId      String
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sceneKey    String
  displayName String
  projectId   String?
  locked      Boolean                 @default(false)
  version     Int                     @default(1)
  refs        StoryProSceneAssetRef[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([userId, sceneKey, projectId])
  @@index([userId, updatedAt])
}

model StoryProSceneAssetRef {
  id           String                    @id @default(cuid())
  assetId      String
  asset        StoryProSceneAsset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  kind         StoryProSceneAssetRefKind
  ossUrl       String
  sortOrder    Int                       @default(0)
  label        String?
  sourceTaskId String?
  createdAt    DateTime                  @default(now())

  @@index([assetId, sortOrder])
}

/// 影视专业版 · 全局风格配置（可按 project 或用户级 profileKey 入库）
model StoryProStyleProfile {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId      String?
  profileKey     String   @default("default")
  displayName    String
  locked         Boolean  @default(false)
  version        Int      @default(1)
  mainStyle      String?
  colorTone      String?
  renderQuality  String?
  anchorZh       String?  @db.Text
  anchorEn       String?  @db.Text
  negativePrompt String?  @db.Text
  refImageUrls   Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, projectId, profileKey])
  @@index([userId, updatedAt])
}

/// 影视专业版 · 角色音频资产（音色样本 / voiceId）
model StoryProCharacterAudioAsset {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterKey String
  displayName  String
  projectId    String?
  locked       Boolean  @default(false)
  version      Int      @default(1)
  voiceLabel   String?
  voiceId      String?
  sampleOssUrl String?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, characterKey, projectId])
  @@index([userId, updatedAt])
}

/// 剧本创作助手 · 定稿前对话历史（定稿后清空，不再写入）
/// workflowKey：scriptHubId / starter:{starterId}；空串为旧版项目级会话（兼容保留）
model StoryProScriptAssistantHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String
  workflowKey String   @default("")
  theme       String?
  messages    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, projectId, workflowKey])
  @@index([userId, updatedAt])
  @@index([userId, projectId])
}

/// 用户自定义提示词模板（LLM / IMAGE 合计最多 8 条活跃；删除软归档保留快照；内置在代码里）
model CanvasPromptTemplate {
  id        String                 @id @default(cuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  engine    CanvasPromptEngineKind
  name      String
  content   String                 @db.Text
  sortOrder Int                    @default(0)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, engine, sortOrder])
  @@index([userId, deletedAt])
}

enum CanvasPromptEngineKind {
  LLM
  IMAGE
}

/// 画布节点级 KIE 任务表（mirror StoryGenerationTask，加 nodeId / inputHash 实现节点缓存）
model CanvasGenerationTask {
  id        String        @id @default(cuid())
  projectId String
  project   CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// 画布内节点 id（与 canvas.nodes[].id 一致）
  nodeId    String

  kind   CanvasGenerationKind
  status CanvasGenerationStatus @default(PENDING)

  /// KIE 模型键（如 nano-banana-pro / gpt-image-1 / kling-image）
  model         String
  kieTaskId     String? @unique
  inputPayload  Json
  resultPayload Json?
  /// 节点输入 + 参数的 sha256，用于缓存命中
  inputHash     String

  ephemeralUrl String?
  ossUrl       String?

  /// 文本类节点结果（kind=TEXT 时使用）
  textOutput String? @db.Text

  failCode    String?
  failMessage String?

  /// canvas v2: 关联到调用的用户 Provider；系统/兜底调用为 null
  providerId String?
  provider   CanvasProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  /// canvas v2: 软删；用于「删除单次结果」（OSS 清理由 cleanup queue 异步处理）
  deletedAt DateTime?

  submittedAt  DateTime?
  completedAt  DateTime?
  lastPolledAt DateTime?
  pollCount    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, submittedAt])
  @@index([projectId, nodeId])
  @@index([projectId, inputHash])
  @@index([providerId])
  @@index([projectId, nodeId, deletedAt, createdAt])
}

/// 画布 OSS 清理队列（mirror StoryOssCleanupQueue）
model CanvasOssCleanupQueue {
  id          String         @id @default(cuid())
  source      String?
  projectId   String?
  project     CanvasProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  ossUrl      String
  notBefore   DateTime       @default(now())
  attempts    Int            @default(0)
  lastTriedAt DateTime?
  lastError   String?
  doneAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doneAt, notBefore])
  @@index([projectId])
}

/// canvas v2 · 用户级 AI/生图 Provider 凭据
model CanvasProvider {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 用户起的别名，例如 "我的 KIE 账号"
  alias           String
  kind            CanvasProviderKind
  /// AES-256-GCM 加密后的 API Key（格式：`v1.<iv>.<cipher>.<authTag>`，base64）
  apiKeyEncrypted String             @db.Text
  /// OPENAI_COMPAT 必填；其余 kind 走默认 baseUrl
  baseUrl         String?
  active          Boolean            @default(true)

  lastTestedAt   DateTime?
  /// "ok" / "error:reason"
  lastTestStatus String?

  models CanvasProviderModel[]
  tasks  CanvasGenerationTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, active])
}

/// canvas v2 · Provider 下的具体模型
model CanvasProviderModel {
  id         String         @id @default(cuid())
  providerId String
  provider   CanvasProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  /// provider 端的模型 id
  modelKey      String
  displayName   String
  role          CanvasModelRole
  description   String?         @db.Text
  /// 节点 UI 渲染参数（JSON Schema-like）
  paramsSchema  Json?
  defaultParams Json?
  enabled       Boolean         @default(true)
  sortOrder     Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, modelKey])
  @@index([providerId, enabled, sortOrder])
  @@index([role])
}

// —— gateway-web BYOK 代理路由 ——

enum GatewayUserSource {
  BOOK_SYNC
  LOCAL
}

enum GatewayProviderKind {
  KIE
  BAILIAN
  DEEPSEEK
  HUNYUAN
  DASHSCOPE
  VOLCENGINE
}

enum GatewayRequestStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum GatewayRequestKind {
  CHAT
  IMAGE
  VIDEO
  OTHER
  TTS
  TRYON
}

enum GatewayMetricsSource {
  VENDOR
  PLATFORM
  UNAVAILABLE
}

enum EcomBillingMode {
  BYOK_SERVICE_FEE
  PLATFORM_METERED
}

enum BillingPersona {
  PLATFORM_CREDIT
  BYOK
}

enum GatewayClientSource {
  GATEWAY_CONSOLE
  CANVAS
  STORY
  TOOL
  E_COMMERCE
  EXTERNAL
}

/**
 * sk-gw 用途：PLATFORM=全站管理员密钥；PERSONAL=个人/Book 关联用
 */
enum GatewayApiKeyScope {
  PLATFORM
  PERSONAL
}

model GatewayUser {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String?
  name         String?
  image        String?
  bookUserId   String?           @unique
  source       GatewayUserSource @default(LOCAL)

  credentials GatewayVendorCredential[]
  apiKeys     GatewayApiKey[]
  requestLogs GatewayRequestLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GatewayVendorCredential {
  id              String              @id @default(cuid())
  userId          String
  user            GatewayUser         @relation(fields: [userId], references: [id], onDelete: Cascade)
  alias           String
  providerKind    GatewayProviderKind
  apiKeyEncrypted String              @db.Text
  baseUrl         String?
  active          Boolean             @default(true)
  lastTestedAt    DateTime?
  lastTestStatus  String?

  // —— 多 Key 路由（gateway-multi-credential）——
  /// 归属范围：个人凭证(USER) 或 团队凭证(TENANT)
  ownerScope           CredentialOwnerScope @default(USER)
  /// 归属对象 id：USER→bookUserId；TENANT→tenantId。回填脚本写入。
  ownerId              String?
  /// 渠道名（用户自定义，如「官方自有」「某代理」），用于路由展示与对账分组
  channel              String?
  /// 同厂商多凭证排序（升序优先）
  sortOrder            Int                  @default(0)
  /// 是否该厂商的默认凭证（同一 ownerScope+ownerId+providerKind 至多一个 true）
  isDefaultForProvider Boolean              @default(false)

  apiKeyBindings GatewayApiKeyCredential[]
  requestLogs    GatewayRequestLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, active])
  @@index([ownerScope, ownerId, providerKind])
}

model GatewayApiKey {
  id            String             @id @default(cuid())
  userId        String
  user          GatewayUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  scope         GatewayApiKeyScope @default(PERSONAL)
  keyPrefix     String
  keyHash       String
  ipWhitelist   Json?
  spendLimitUsd Decimal?           @db.Decimal(12, 4)
  revokedAt     DateTime?
  /// 平台托管 Key：前台/Gateway 控制台隐藏 CRUD，绑定平台厂商凭证
  managedByPlatform Boolean          @default(false)
  billingScope      String? // personal | team

  bindings       GatewayApiKeyCredential[]
  requestLogs    GatewayRequestLog[]
  linkedBookUser User?
  linkedTenant   Tenant?                 @relation("TenantGatewayKey")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, revokedAt])
  @@index([keyPrefix])
  @@index([managedByPlatform])
}

model GatewayApiKeyCredential {
  apiKeyId     String
  credentialId String
  apiKey       GatewayApiKey           @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  credential   GatewayVendorCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@id([apiKeyId, credentialId])
}

model GatewayRequestLog {
  id           String                   @id @default(cuid())
  userId       String
  user         GatewayUser              @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeyId     String
  apiKey       GatewayApiKey            @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  credentialId String?
  credential   GatewayVendorCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  providerKind   GatewayProviderKind?
  model          String
  endpoint       String
  requestKind    GatewayRequestKind   @default(OTHER)
  status         GatewayRequestStatus @default(PENDING)
  externalTaskId String?
  clientSource   GatewayClientSource  @default(EXTERNAL)
  clientPage     String?
  storyProjectId String?
  storyTaskId    String?

  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  hasTokenUsage    Boolean              @default(false)
  metricsSource    GatewayMetricsSource @default(UNAVAILABLE)
  durationMs       Int?
  vendorDurationMs Int?

  pricingModelKey         String?
  pricingTierRaw          String?
  billingKind             String?
  vendorListUnitCostYuan  Decimal? @db.Decimal(16, 8)
  estimatedVendorCostYuan Decimal? @db.Decimal(16, 6)

  // —— 统一积分计费快照（unified-credit-billing）——
  billingMode       CreditBillingMode? // PLATFORM_CREDIT | BYOK
  canonicalModelKey String? // 归口模型键（ModelCatalog.canonicalKey）
  creditsCharged    Int? // 本次实际扣减积分（模式 A）
  costSnapshotYuan  Decimal?           @db.Decimal(16, 6) // 写日志时的渠道净成本快照
  marginSnapshot    Decimal?           @db.Decimal(6, 4) // 写日志时的毛利率快照（0~1）
  seatId            String? // 团队席位（占用人）

  // —— 多租户 + 多 Key 对账快照（gateway-multi-credential-and-tenant）——
  tenantId                String? // 计费归属租户（个人空间=个人租户）
  actorBookUserId         String? // 实际操作的 Book 用户（团队下区分成员）
  credentialAliasSnapshot String? // 实际使用凭证别名快照（对账用）
  channelSnapshot         String? // 实际使用凭证渠道快照（按渠道对账）
  staffFlag               Boolean          @default(false)
  billingPersonaSnap      BillingPersona?

  // —— Book 财务结算快照（Gateway 只记调用；套餐扣次/扣分由 Book 写入）——
  settlementKind          BillingSettlementKind?
  byokTaskKind            ByokTaskKind?
  billingCategory         BillingCategory?
  quotaDelta              Int? // 套餐内扣次（通常 1）
  includedUsedAfter       Int?
  includedRemainingAfter  Int?

  inputSummary  Json?
  resultSummary Json?
  failCode      String?
  failMessage   String? @db.Text

  submittedAt  DateTime  @default(now())
  completedAt  DateTime?
  lastPolledAt DateTime?
  pollCount    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, submittedAt])
  @@index([apiKeyId, submittedAt])
  @@index([externalTaskId])
  @@index([status])
  @@index([clientSource, submittedAt])
  @@index([tenantId, submittedAt])
  @@index([actorBookUserId, submittedAt])
  @@index([channelSnapshot])
  @@index([staffFlag, submittedAt])
  @@index([billingPersonaSnap, submittedAt])
  @@index([settlementKind, submittedAt])
  @@index([actorBookUserId, settlementKind])
  @@index([billingCategory, submittedAt])
}

/// Book 侧统一结算流水：每笔 Gateway 成功调用的扣积分 / 扣套餐次快照（财务对帐真源）
enum BillingSettlementKind {
  BYOK_QUOTA_INCLUDED // BYOK 套餐内扣次（0 积分）
  BYOK_QUOTA_OVERAGE // BYOK 超额扣轻量包积分
  PLATFORM_CREDIT // 平台代付扣积分
  PLATFORM_VIDEO // 平台代付视频（RESERVE/SETTLE）
  METER_ONLY // BYOK 未映射任务类型，仅计量
  NONE // 成功但未扣费/扣次
}

model BillingSettlementLine {
  id                     String                @id @default(cuid())
  gatewayLogId           String                @unique
  ownerType              CreditOwnerType
  ownerId                String
  actorBookUserId        String?
  periodKey              String // YYYY-MM
  settlementKind         BillingSettlementKind
  byokTaskKind           ByokTaskKind?
  billingCategory        BillingCategory?
  tryonModelKey          String?
  quotaDelta             Int                   @default(0)
  monthlyIncluded        Int?
  includedUsedAfter      Int?
  includedRemainingAfter Int?
  isOverage              Boolean               @default(false)
  creditsCharged         Int                   @default(0)
  creditLedgerId         String?
  canonicalModelKey      String?
  requestKind            GatewayRequestKind?
  clientPage             String?
  feeDescription         String?
  submittedAt            DateTime
  createdAt              DateTime              @default(now())

  @@index([ownerType, ownerId, periodKey])
  @@index([actorBookUserId, periodKey])
  @@index([settlementKind, submittedAt])
  @@index([byokTaskKind, periodKey])
  @@index([billingCategory, periodKey])
}

// ============================================================
// 统一积分计费体系（unified-credit-billing）
// 规则：挂牌价 P = 渠道净成本 C × M；积分/次 U = round(P ÷ creditAnchorYuan)
// 用户只见挂牌价/积分；成本与折扣仅后台财务可见。
// ============================================================

enum CreditChannel {
  OWN // 厂商自有/官方价
  CHANNEL // 渠道折扣
  RESELLER // 代理转售
}

enum CreditCostUnit {
  PER_SEC // 视频按秒
  PER_IMAGE // 图片按张
  PER_KTOKEN // LLM 按千 token
}

enum MembershipFamily {
  PERSONAL // 创作会员（个人）
  TEAM // 团队版会员
}

enum MembershipInterval {
  MONTH
  YEAR
}

enum CreditOwnerType {
  USER
  TENANT
}

enum CreditLedgerType {
  GRANT // 套餐发放
  CONSUME // 生成扣减
  REFUND // 失败/取消返还
  EXPIRE // 周期过期清零
  TOPUP // 额外积分包充值
  ADJUST // 人工校正
  RESERVE // 冻结预扣（视频先冻结后渲染）
  SETTLE // 冻结转实扣（视频渲染成功结算）
  RELEASE // 解冻返还（厂商全失败）
}

enum CreditBillingMode {
  PLATFORM_CREDIT // 平台 Key + 会员积分
  BYOK // 自带 Key，仅技术服务费 + 资源费
}

enum ResourceMeterType {
  OSS_GB_MONTH // 对象存储 GB·月
  EGRESS_GB // 出网流量 GB
  TASK_COUNT // 任务调度次数
}

/// 全局计费参数（单例 id="default"）
model PlatformPricingConfig {
  id                  String   @id @default("default")
  creditAnchorYuan    Decimal  @default("0.04") @db.Decimal(10, 4) // 1 积分 = ¥0.04 挂牌锚定
  defaultMarginM      Decimal  @default("2.5") @db.Decimal(6, 3) // 默认系数 M（2.5 → 毛利 60%）
  minMarginGuard      Decimal  @default("0.30") @db.Decimal(6, 4) // 文本/图像毛利护栏（低于则阻断）
  defaultVideoSec     Int      @default(15) // 视频默认/封顶计费秒数（财务 2.0：15s）
  videoMarginM        Decimal  @default("4") @db.Decimal(6, 3) // 视频专项系数 M（4 → 75% 毛利）
  videoMinMarginGuard Decimal  @default("0.75") @db.Decimal(6, 4) // 视频专项毛利护栏 ≥75%
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

/// 渠道/厂商成本与折扣（成本与折扣的唯一来源，仅后台可见）
model ModelCostProfile {
  id                String         @id @default(cuid())
  vendor            String // aliyun / kie / volcengine ...
  canonicalModelKey String // 归口模型键（ModelCatalog.canonicalKey）
  channel           CreditChannel  @default(CHANNEL)
  credentialId      String? // 可选：绑定具体凭证（多 Key）
  unit              CreditCostUnit
  tierRaw           String? // 720P / 1080P / 1K 等
  listCostYuan      Decimal        @db.Decimal(16, 8) // 厂商挂牌成本
  discountRate      Decimal        @default("0") @db.Decimal(6, 4) // 渠道折扣 0~1（0.6=六折省）
  netCostYuan       Decimal        @db.Decimal(16, 8) // 派生：listCostYuan × (1 - discountRate)
  effectiveFrom     DateTime       @default(now())
  effectiveTo       DateTime?
  active            Boolean        @default(true)
  note              String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([canonicalModelKey, active])
  @@index([vendor, channel])
}

/// 已发布的模型积分报价（派生自 ModelCostProfile，对外报价页读它）
model ModelCreditPrice {
  id                String         @id @default(cuid())
  canonicalModelKey String         @unique
  displayName       String
  vendor            String
  unit              CreditCostUnit
  tierRaw           String?
  netCostYuan       Decimal        @db.Decimal(16, 8) // 取价时的净成本快照
  marginM           Decimal        @db.Decimal(6, 3) // 取价时的系数 M
  listPriceYuan     Decimal        @db.Decimal(16, 6) // 挂牌价 = netCost × M
  creditsPerUnit    Int // 积分/次（或 /秒、/张、/千token）
  baseMarginRate    Decimal        @db.Decimal(6, 4) // 标准锚定下毛利率
  formulaSnapshot   Json // 公式与中间值快照，供后台查阅
  active            Boolean        @default(true)
  publishedAt       DateTime       @default(now())
  publishedBy       String?

  @@index([active])
}

enum AppModelOfferingStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

/// 媒介四槽（文生图 / 图生视频 / 视频生视频 / 纯文本）
enum ModelMediaKind {
  TEXT_TO_IMAGE
  IMAGE_TO_VIDEO
  VIDEO_TO_VIDEO
  TEXT_LLM
}

/// Gateway 统一注册：同一 canonical 的多厂商路由
model GatewayModelRoute {
  id                String              @id @default(cuid())
  canonicalModelKey String
  catalog           ModelCatalog        @relation(fields: [canonicalModelKey], references: [canonicalKey], onDelete: Cascade)
  vendor            String
  modelKey          String
  providerKind      GatewayProviderKind
  active            Boolean             @default(true)
  sortOrder         Int                 @default(0)
  note              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([canonicalModelKey, vendor, modelKey])
  @@index([modelKey, active])
  @@index([canonicalModelKey, active])
}

/// 四媒介槽默认 canonical（应用无用户选模时的 fallback）
model PlatformMediaDefault {
  mediaKind           ModelMediaKind @id
  defaultCanonicalKey String
  updatedAt           DateTime       @updatedAt
}

/// 平台代付：每个 canonical 一行上架配置
model AppModelOffering {
  id                      String                 @id @default(cuid())
  canonicalModelKey       String                 @unique
  role                    CanvasModelRole
  displayName             String
  requestKind             GatewayRequestKind
  activeVendor            String?
  activeCanonicalKey      String?
  activeProviderKind      GatewayProviderKind?
  activeModelKey          String?
  publishedCreditsPerUnit Int?
  estimatedMargin         Decimal?               @db.Decimal(6, 4)
  routeLocked             Boolean                @default(false)
  status                  AppModelOfferingStatus @default(DRAFT)
  sortOrder               Int                    @default(0)

  candidates   AppModelCandidate[]
  publishLogs  OfferingPublishLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role, status])
}

/// 同 canonical 多厂商候选（自动选型 / 手动切换）
model AppModelCandidate {
  id                String              @id @default(cuid())
  offeringId        String
  vendor            String
  canonicalModelKey String
  providerKind      GatewayProviderKind
  modelKey          String
  netCostYuan       Decimal             @db.Decimal(16, 8)
  marginOk          Boolean             @default(true)
  autoScore         Decimal?            @db.Decimal(12, 6)
  isActiveRoute     Boolean             @default(false)

  offering AppModelOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([offeringId, isActiveRoute])
  @@index([canonicalModelKey])
}

model OfferingPublishLog {
  id                String   @id @default(cuid())
  offeringId        String
  action            String // AUTO_PUBLISH / MANUAL_LOCK
  fromCanonicalKey  String?
  toCanonicalKey    String?
  fromProviderKind  String?
  toProviderKind    String?
  netCostYuan       Decimal? @db.Decimal(16, 8)
  estimatedMargin   Decimal? @db.Decimal(6, 4)
  publishedBy       String?
  note              String?  @db.Text

  offering AppModelOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([offeringId, createdAt])
}

/// 会员套餐（个人/团队 × 月/年 × 五档）
model MembershipPlan {
  id                  String             @id @default(cuid())
  family              MembershipFamily
  interval            MembershipInterval
  tier                String // 标准版/进阶版/高级版/豪华版/至尊版
  sortOrder           Int                @default(0)
  priceYuan           Decimal            @db.Decimal(12, 2) // 套餐价（团队=基础含席位价）
  originalYuan        Decimal?           @db.Decimal(12, 2) // 划线原价
  promoLabel          String? // 限时67折等
  monthlyCredits      Int // 月积分（团队=每席位）
  videoMonthlyCredits Int                @default(0) // 视频专项池月额度（0 = 不单独分池，复用通用池）
  pricePerCreditYuan  Decimal?           @db.Decimal(12, 6) // 派生快照：priceYuan ÷ monthlyCredits（逐档积分换算单价）
  includedSeats       Int                @default(1) // 套餐含席位数
  active              Boolean            @default(true)
  seatTiers           TeamSeatTier[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([family, interval, tier])
  @@index([active, sortOrder])
}

/// 团队席位带（图1/2：紫色按席位变化）
model TeamSeatTier {
  id                  String         @id @default(cuid())
  planId              String
  plan                MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  seatMin             Int
  seatMax             Int? // null = 不封顶（10人以上）
  perSeatPriceYuan    Decimal        @db.Decimal(12, 2)
  perSeatCredits      Int
  perSeatVideoCredits Int            @default(0) // 每席视频专项池额度（0 = 复用通用池）
  sortOrder           Int            @default(0)

  @@index([planId, sortOrder])
}

/// 积分账户（个人或租户）
model CreditAccount {
  id                   String          @id @default(cuid())
  ownerType            CreditOwnerType
  ownerId              String // userId 或 tenantId
  balanceCredits       Int             @default(0) // 通用池可用余额
  monthlyGrantCredits  Int             @default(0) // 当前套餐月发放额
  reservedCredits      Int             @default(0) // 通用池冻结中（已 RESERVE 未 SETTLE/RELEASE）
  videoBalanceCredits  Int             @default(0) // 视频专项池可用余额
  videoMonthlyGrant    Int             @default(0) // 视频专项池月发放额
  videoReservedCredits Int             @default(0) // 视频专项池冻结中
  pricePerCreditYuan   Decimal?        @db.Decimal(12, 6) // 该账户档位「每积分单价」快照（逐档积分换算）
  perSeatCapCredits    Int? // 子账号人均上限（可选）
  planId               String?
  currentPeriodEnd     DateTime?
  entries              CreditLedger[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([ownerType, ownerId])
}

/// 积分流水
model CreditLedger {
  id               String           @id @default(cuid())
  accountId        String
  account          CreditAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type             CreditLedgerType
  credits          Int // 入正出负
  balanceAfter     Int
  actorUserId      String? // 团队中实际操作人
  refType          String? // gateway_log / plan_grant / topup_order ...
  refId            String?
  costSnapshotYuan Decimal?         @db.Decimal(16, 6)
  pool             CreditPool       @default(GENERAL) // 通用池 / 视频专项池
  idempotencyKey   String?          @unique
  description      String?
  staffFlag        Boolean          @default(false)
  billingPersonaSnap BillingPersona?
  createdAt        DateTime         @default(now())

  @@index([accountId, createdAt])
  @@index([staffFlag, createdAt])
}

enum CreditPool {
  GENERAL // 通用积分池（文本/图像/其它）
  VIDEO // 视频专项池
}

/// 调价提案审批流（运营提交 → 财务复核 → 超管终审 → 生效）
enum PlanChangeStatus {
  DRAFT // 草稿
  SIMULATED // 已测算
  FINANCE_REVIEW // 财务复核中
  APPROVED // 超管终审通过（待生效）
  REJECTED // 驳回
  EFFECTIVE // 已生效
  CANCELLED // 已撤销
}

/// 调价提案 + 六维测算 + 反向验算快照（全程留痕）
model PlanChangeProposal {
  id                String           @id @default(cuid())
  title             String
  status            PlanChangeStatus @default(DRAFT)
  /// 变更目标（套餐/视频 M/护栏等）的结构化补丁
  payload           Json
  /// 六维测算报告快照（基础成本/扣费变动/毛利校验/月度成本上限/营收模拟/用户影响）
  simulation        Json?
  /// 财务反向验算快照（模式 A/B）
  reverseCheck      Json?
  /// 测算/校验是否全部通过（任一档毛利<阈值则 false）
  marginPassed      Boolean          @default(false)
  createdBy         String
  financeReviewedBy String?
  approvedBy        String?
  rejectedReason    String?
  effectiveAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  events PlanChangeEvent[]

  @@index([status, createdAt])
}

/// 提案状态流转留痕
model PlanChangeEvent {
  id         String             @id @default(cuid())
  proposalId String
  proposal   PlanChangeProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  fromStatus PlanChangeStatus?
  toStatus   PlanChangeStatus
  actorId    String
  actorRole  String?
  note       String?
  createdAt  DateTime           @default(now())

  @@index([proposalId, createdAt])
}

/// BYOK 技术服务费配置（个人 / 团队两档）
model ByokServiceConfig {
  id                 String             @id @default(cuid())
  scopeKey           String             @unique // personal | team-seat
  label              String
  techServiceFeeYuan Decimal            @db.Decimal(12, 2)
  interval           MembershipInterval @default(MONTH)
  minSeats           Int? // 团队最低席位数（仅 team-seat）
  active             Boolean            @default(true)
  note               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

/// BYOK 任务类型（套餐内额度 + 超额轻量包扣分）
enum ByokTaskKind {
  TEXT_TO_IMAGE
  IMAGE_TO_VIDEO
  VIDEO_TO_VIDEO
  VIDEO_UNDERSTANDING
  TTS
}

/// 七类计费 taxonomy（BYOK + 平台代付报表/结算共用；含无含次的 TEXT / OTHER）
enum BillingCategory {
  TEXT_TO_IMAGE
  IMAGE_TO_VIDEO
  VIDEO_TO_VIDEO
  VIDEO_UNDERSTANDING
  TTS
  TEXT
  OTHER
}

/// BYOK 套餐内月度额度与超额扣分（从轻量包/general 池扣）
model ByokTaskQuota {
  id              String       @id @default(cuid())
  scopeKey        String // personal | team-seat
  taskKind        ByokTaskKind
  label           String
  monthlyIncluded Int
  overageCredits  Int
  active          Boolean      @default(true)
  updatedAt       DateTime     @updatedAt

  @@unique([scopeKey, taskKind])
  @@index([scopeKey])
}

enum ByokSubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

/// BYOK 套餐订阅（个人或团队租户；与积分会员套餐并列）
model ByokSubscription {
  id                 String                 @id @default(cuid())
  ownerType          CreditOwnerType
  ownerId            String
  scopeKey           String // personal | team-seat
  status             ByokSubscriptionStatus @default(ACTIVE)
  seats              Int                    @default(1)
  techServiceFeeYuan Decimal                @db.Decimal(12, 2)
  periodStart        DateTime
  periodEnd          DateTime
  lastOrderId        String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([ownerType, ownerId, status])
  @@index([periodEnd])
  @@index([scopeKey, status])
}

/// BYOK 月度任务用量（套餐内 + 超额）
model ByokUsageMonthly {
  id              String          @id @default(cuid())
  ownerType       CreditOwnerType
  ownerId         String
  scopeKey        String // personal | team-seat
  periodKey       String // YYYY-MM
  taskKind        ByokTaskKind
  seatsSnapshot   Int             @default(1)
  includedUsed    Int             @default(0)
  overageUsed     Int             @default(0)
  overageCredits  Int             @default(0)
  updatedAt       DateTime        @updatedAt

  @@unique([ownerType, ownerId, periodKey, taskKind])
  @@index([periodKey, scopeKey])
  @@index([ownerType, ownerId, periodKey])
}

/// BYOK 资源计量单价（用量 × 系数）
model ResourceMeterRate {
  id              String            @id @default(cuid())
  resourceType    ResourceMeterType @unique
  coefficientYuan Decimal           @db.Decimal(16, 8) // 每单位资源单价
  unitLabel       String // GB·月 / GB / 次
  active          Boolean           @default(true)
  updatedAt       DateTime          @updatedAt
}

/// BYOK 资源用量事件
model ResourceMeterEvent {
  id           String            @id @default(cuid())
  ownerType    CreditOwnerType
  ownerId      String
  resourceType ResourceMeterType
  quantity     Decimal           @db.Decimal(16, 6)
  costYuan     Decimal           @db.Decimal(16, 6) // quantity × coefficient 快照
  refType      String?
  refId        String?
  periodKey    String // YYYY-MM 结算桶
  createdAt    DateTime          @default(now())

  @@index([ownerType, ownerId, periodKey])
}

// ============================================================
// 多租户 / 团队体系（gateway-multi-credential-and-tenant）
// 每个用户至少属于一个 PERSONAL 租户（个人空间）；团队/公司为 TEAM 租户。
// 计费账户经 CreditAccount(ownerType=TENANT, ownerId=tenantId) 共享积分池。
// ============================================================

enum CredentialOwnerScope {
  USER // 个人凭证
  TENANT // 团队/公司凭证（成员共享）
}

enum TenantType {
  PERSONAL // 个人空间（每个用户自动拥有一个）
  TEAM // 团队 / 工作室 / 公司
}

enum TenantRole {
  OWNER // 主账号：计费、Key、团队配置、转移所有权
  ADMIN // 管理员：成员/席位/资产管理，不可计费充值
  MEMBER // 普通成员：仅使用 + 自有私有资产
}

enum TenantMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum SeatStatus {
  ACTIVE // 已分配占用
  IDLE // 空闲可分配
  DISABLED // 停用
}

enum TenantInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

/// 资产可见域（跨工具统一）：个人私有 / 团队公共库
enum AssetVisibility {
  PRIVATE // 仅本人可见（个人空间或团队内成员私有库）
  TEAM_PUBLIC // 团队公共库：成员可见可用，仅 OWNER/ADMIN 可删/改归属
}

/// 租户（个人空间 / 团队 / 公司）
model Tenant {
  id                String              @id @default(cuid())
  type              TenantType          @default(PERSONAL)
  name              String
  ownerUserId       String
  owner             User                @relation("TenantOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  /// 关联会员套餐（团队套餐）；个人租户可为空（走个人会员）
  planId            String?
  packageLevel      String? // 标准版/进阶版/... 快照
  interval          MembershipInterval?
  seatLimit         Int                 @default(1) // 席位总数（含套餐内 + 加购）
  maxConcurrency    Int                 @default(2) // 并发任务上限（里程碑 7 Redis 启用）
  perSeatCapCredits Int? // 子账号人均月积分上限（可选）
  currentPeriodEnd  DateTime?
  status            String              @default("ACTIVE") // ACTIVE / SUSPENDED
  /// 团队 PLATFORM_CREDIT 自动托管 sk-gw
  gatewayApiKeyId   String?             @unique
  gatewayApiKey     GatewayApiKey?      @relation("TenantGatewayKey", fields: [gatewayApiKeyId], references: [id], onDelete: SetNull)

  members TenantMember[]
  seats   Seat[]
  invites TenantInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([type, status])
}

/// 租户成员
model TenantMember {
  id                String             @id @default(cuid())
  tenantId          String
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  role              TenantRole         @default(MEMBER)
  status            TenantMemberStatus @default(ACTIVE)
  seatId            String?            @unique
  seat              Seat?              @relation(fields: [seatId], references: [id], onDelete: SetNull)
  /// 成员个人月积分上限（覆盖租户 perSeatCapCredits）
  monthlyCapCredits Int?
  joinedAt          DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId, status])
  @@index([userId])
}

/// 团队席位
model Seat {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label     String? // 席位标签
  status    SeatStatus    @default(IDLE)
  member    TenantMember?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([tenantId, status])
}

/// 团队邀请
model TenantInvite {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String
  token       String             @unique
  role        TenantRole         @default(MEMBER)
  status      TenantInviteStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdById String?
  createdBy   User?              @relation("TenantInviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([tenantId, status])
  @@index([email])
}
