# next dev 自动加载（优先级低于 .env*.local）。本地请仍用 .env.local 存放密钥与 DATABASE_URL。
NEXTAUTH_URL=http://localhost:3000
TOOLS_PUBLIC_ORIGIN=http://localhost:3001

# finance-web（npm run dev -p 3002）：个人中心 / 管理后台「财务控制台」外链 + CORS
NEXT_PUBLIC_FINANCE_WEB_ORIGIN=http://localhost:3002
FINANCE_WEB_ORIGINS=http://localhost:3002

# finance-web 本地联调：允许 ?devUserId= 拉取账单明细（非 production）
FINANCE_ALLOW_DEV_USER_QUERY=1
