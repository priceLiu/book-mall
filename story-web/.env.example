# story-web — 本地开发（复制为 .env.local 按需覆盖）

# 首页「发现更多」视频（16:9 mp4）
# 本地开发可放 public/video；上线前执行：
#   pnpm upload:landing-videos
# 凭证读取 ../tool-web/.env.local，上传后生成 src/shared/landing-videos.manifest.json
NEXT_PUBLIC_BOOK_MALL_URL=http://localhost:3000
BOOK_MALL_URL=http://localhost:3000
MAIN_SITE_ORIGIN=http://localhost:3000

TOOLS_SSO_SERVER_SECRET=your-shared-secret-min-16-chars
TOOLS_SSO_JWT_SECRET=your-jwt-secret-min-16-chars

NEXT_PUBLIC_STORY_WEB_ORIGIN=http://localhost:3003
STORY_PUBLIC_ORIGIN=http://localhost:3003

NEXT_PUBLIC_TOOL_WEB_ORIGIN=http://localhost:3001

# 跨门户导航（PortalNav 互链，供已登录用户无感换票跳转）
NEXT_PUBLIC_CANVAS_WEB_ORIGIN=http://localhost:3004
NEXT_PUBLIC_QUICK_REPLICA_ORIGIN=http://localhost:3008
NEXT_PUBLIC_ECOMMERCE_WEB_ORIGIN=http://localhost:3007
