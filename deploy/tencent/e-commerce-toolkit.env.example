# e-commerce-toolkit · CloudBase 环境变量示例
PORT=3007
NODE_ENV=production
# 三者至少配 MAIN_SITE_ORIGIN；entrypoint 会用 BOOK_MALL_URL / NEXT_PUBLIC 补全
MAIN_SITE_ORIGIN=https://book.ai-code8.com
BOOK_MALL_URL=https://book.ai-code8.com
ECOMMERCE_PUBLIC_ORIGIN=https://ecom.ai-code8.com
NEXT_PUBLIC_ECOMMERCE_WEB_ORIGIN=https://ecom.ai-code8.com
NEXT_PUBLIC_BOOK_MALL_URL=https://book.ai-code8.com
# 与 book-mall 完全一致
TOOLS_SSO_SERVER_SECRET=
TOOLS_SSO_JWT_SECRET=
