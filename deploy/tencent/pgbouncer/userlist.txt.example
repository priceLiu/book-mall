; PgBouncer 认证清单(md5 模式)。复制为 userlist.txt 后填真实值,切勿提交真实口令到仓库。
;
; 生成 md5 哈希(注意:hash = "md5" + md5(password + username)):
;   echo -n "<password><username>" | md5sum
;   例:用户 aitools_admin → echo -n "<PASS>aitools_admin" | md5sum
;   然后写成:"aitools_admin" "md5<上一步的32位十六进制>"
;
; 应用业务账号(与 CDB 实际账号一致)
"aitools_admin" "md5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

; PgBouncer 管理/统计账号(用于 SHOW POOLS / SHOW STATS;可在 CDB 建只读角色或仅本地)
"pgbouncer_admin" "md5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
"pgbouncer_stat"  "md5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
