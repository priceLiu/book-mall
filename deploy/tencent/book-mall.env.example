# 主站 book-mall — Docker / Compose 用（复制为 book-mall.env 后填写）
# cp deploy/tencent/book-mall.env.example deploy/tencent/book-mall.env

NODE_ENV=production

# PostgreSQL（容器启动时会 prisma migrate deploy）
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/tool_mall?sslmode=require

# 公网访问主站的 Origin（无路径）
NEXTAUTH_URL=https://book.ai-code8.com
NEXTAUTH_SECRET=请替换为长随机串

# 逗号分隔管理员邮箱（首次 seed 前可先不配）
ADMIN_EMAILS=

# —— 工具站 SSO（须与工具站环境变量一致）——
TOOLS_PUBLIC_ORIGIN=https://tool.ai-code8.com
# 可选：仍为默认网关域名时，单独指定用户实际访问的工具站 origin（与上一行二选一或并存）
# TOOLS_SSO_ISSUE_ORIGIN=https://tool.ai-code8.com
TOOLS_SSO_SERVER_SECRET=与_tool-web_相同至少16位
TOOLS_SSO_JWT_SECRET=与_tool-web_相同另一条至少16位

# —— 财务控制台（须与 finance-web 部署根地址一致）——
NEXT_PUBLIC_FINANCE_WEB_ORIGIN=https://f.ai-code8.com
FINANCE_WEB_ORIGINS=https://f.ai-code8.com
NEXT_PUBLIC_STORY_WEB_ORIGIN=https://story.ai-code8.com
STORY_WEB_ORIGINS=https://story.ai-code8.com
NEXT_PUBLIC_CANVAS_WEB_ORIGIN=https://canvas.ai-code8.com
CANVAS_WEB_ORIGINS=https://canvas.ai-code8.com
NEXT_PUBLIC_PROMPT_OPTIMIZER_ORIGIN=https://prompt.ai-code8.com
PROMPT_OPTIMIZER_PUBLIC_ORIGIN=https://prompt.ai-code8.com
NEXT_PUBLIC_GATEWAY_WEB_ORIGIN=https://gateway.ai-code8.com
# 跨子域共享 NextAuth Cookie（finance-web 同源代理转发会话）；entrypoint 生产默认 .ai-code8.com
NEXTAUTH_COOKIE_DOMAIN=.ai-code8.com

# —— OSS（漫剧 KIE 结果持久化、工具资源库删除等；与 tool-web 同一 bucket 即可）——
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=oss-cn-guangzhou
# OSS_ENDPOINT=
# OSS_PUBLIC_URL_BASE=

# —— story-web 漫剧 AI（KIE + poll/callback）——
KIE_API_KEY=
KIE_CALLBACK_TOKEN=
STORY_AI_PUBLIC_BASE=https://book.ai-code8.com
STORY_AI_POLL_TOKEN=
