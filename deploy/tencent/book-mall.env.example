# 主站 book-mall — Docker / Compose 用（复制为 book-mall.env 后填写）
# cp deploy/tencent/book-mall.env.example deploy/tencent/book-mall.env

NODE_ENV=production

# PostgreSQL（容器启动时会 prisma migrate deploy）
#
# 【推荐 · 经 PgBouncer 治本】现网多副本 + 3 个 poll-loop 子进程必上 pooler，消除腾讯云直连
# 空闲 TCP 被回收导致的「Server has closed the connection / Timed out fetching a new connection」。
# 部署见 deploy/tencent/pgbouncer/（pgbouncer.ini + docker-compose.yml + userlist）。
#  - 运行时 DATABASE_URL → PgBouncer:6432，务必带 pgbouncer=true（Prisma 关预处理语句以兼容 transaction 池）。
#  - 迁移 DIRECT_DATABASE_URL → 直连 CDB:24155（prisma schema directUrl 引用；db:deploy 自动走它，不经池）。
#  - connection_limit 按 deploy/tencent/pgbouncer/README.md 连接预算表：副本数×limit + poll×1 + 预留 ≤ pool_size。
DATABASE_URL=postgresql://USER:PASSWORD@pgbouncer.internal:6432/tool_mall?sslmode=require&pgbouncer=true&connection_limit=15&pool_timeout=30&connect_timeout=15
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:24155/tool_mall?sslmode=require&connect_timeout=30
#
# 【备选 · 直连无 pooler（止血）】小流量/单容器可直连；务必显式带 connection_limit（生产不自动注入）。
# 此时 DIRECT_DATABASE_URL 填同一直连串即可（迁移与运行同库）。
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:24155/tool_mall?sslmode=require&connection_limit=30&pool_timeout=30&connect_timeout=15
# DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:24155/tool_mall?sslmode=require&connect_timeout=30

# 公网访问主站的 Origin（无路径）
NEXTAUTH_URL=https://book.ai-code8.com
NEXTAUTH_SECRET=请替换为长随机串

# 逗号分隔管理员邮箱（首次 seed 前可先不配）
ADMIN_EMAILS=
# 逗号分隔管理员手机号（seed 时提升 role=ADMIN；与 ADMIN_EMAILS 可并用）
ADMIN_PHONES=

# —— 手机号 / 短信（详见 docs/手机验证码 todo.md）——
# 阶段 A（短信未开通，可先上生产）：mock + bypass 默认开启
SMS_PROVIDER=mock
# SMS_ALLOW_BYPASS_CODE=1

# 阶段 B（短信已开通）：改为 tencent，且必须 SMS_ALLOW_BYPASS_CODE=0
# SMS_PROVIDER=tencent
# SMS_ALLOW_BYPASS_CODE=0
# TENCENT_SMS_SECRET_ID=
# TENCENT_SMS_SECRET_KEY=
# TENCENT_SMS_REGION=ap-guangzhou
# TENCENT_SMS_SDK_APP_ID=
# TENCENT_SMS_SIGN_NAME=
# TENCENT_SMS_TEMPLATE_REGISTER=
# TENCENT_SMS_TEMPLATE_LOGIN=
# TENCENT_SMS_TEMPLATE_BIND=
# TENCENT_SMS_TEMPLATE_TEAM_INVITE=

# 生产切勿开启开发测试登录 /dev/auth
# ALLOW_DEV_AUTH=1

# —— 工具站 SSO（须与工具站环境变量一致）——
TOOLS_PUBLIC_ORIGIN=https://tool.ai-code8.com
# 可选：仍为默认网关域名时，单独指定用户实际访问的工具站 origin（与上一行二选一或并存）
# TOOLS_SSO_ISSUE_ORIGIN=https://tool.ai-code8.com
TOOLS_SSO_SERVER_SECRET=与_tool-web_相同至少16位
TOOLS_SSO_JWT_SECRET=与_tool-web_相同另一条至少16位

# —— 财务控制台（须与 finance-web 部署根地址一致）——
NEXT_PUBLIC_FINANCE_WEB_ORIGIN=https://f.ai-code8.com
FINANCE_WEB_ORIGINS=https://f.ai-code8.com
NEXT_PUBLIC_STORY_WEB_ORIGIN=https://story.ai-code8.com
STORY_WEB_ORIGINS=https://story.ai-code8.com
NEXT_PUBLIC_CANVAS_WEB_ORIGIN=https://canvas.ai-code8.com
CANVAS_WEB_ORIGINS=https://canvas.ai-code8.com
NEXT_PUBLIC_PROMPT_OPTIMIZER_ORIGIN=https://prompt.ai-code8.com
PROMPT_OPTIMIZER_PUBLIC_ORIGIN=https://prompt.ai-code8.com
NEXT_PUBLIC_GATEWAY_WEB_ORIGIN=https://gateway.ai-code8.com
# 跨子域共享 NextAuth Cookie（finance-web 同源代理转发会话）；entrypoint 生产默认 .ai-code8.com
NEXTAUTH_COOKIE_DOMAIN=.ai-code8.com

# —— 全站 federated logout（个人中心退出登录）——
# 逗号分隔须清 tools_token 的子站 Origin。未设置时生产默认仅 tool + canvas（避免未发版子站 404 卡死退出）。
# story / ecom / prompt 发版 /api/tools-logout 后按需追加，例如：
# FEDERATED_TOOLS_LOGOUT_ORIGINS=https://tool.ai-code8.com,https://canvas.ai-code8.com,https://story.ai-code8.com

# —— OSS（漫剧 KIE 结果持久化、工具资源库删除等；与 tool-web 同一 bucket 即可）——
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=oss-cn-guangzhou
# OSS_ENDPOINT=
# OSS_PUBLIC_URL_BASE=

# —— story-web 漫剧 AI（KIE + poll/callback）——
KIE_API_KEY=
KIE_CALLBACK_TOKEN=
STORY_AI_PUBLIC_BASE=https://book.ai-code8.com
STORY_AI_POLL_TOKEN=

# —— 单会话（新登录挤掉旧会话 + 子站 introspect 校验）——
SINGLE_SESSION_ENFORCE=1
SINGLE_SESSION_RECHECK_SEC=60

# 可选：存量大团队同步并发 pnpm --dir book-mall exec tsx scripts/sync-team-max-concurrency.ts
