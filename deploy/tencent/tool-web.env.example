# 工具站 tool-web — Docker / Compose 用（复制为 tool-web.env 后填写）
# cp deploy/tencent/tool-web.env.example deploy/tencent/tool-web.env

NODE_ENV=production

# 公网主站 Origin（无末尾 /），须与主站 NEXTAUTH_URL 同源语义一致
MAIN_SITE_ORIGIN=https://book.ai-code8.com

# 须与主站 book-mall 中完全一致
TOOLS_SSO_SERVER_SECRET=与主站相同至少16位
TOOLS_SSO_JWT_SECRET=与主站相同另一条至少16位

# 与 book-mall TOOLS_PUBLIC_ORIGIN 完全一致（用于换票后 Location / Cookie 公网地址）
TOOLS_PUBLIC_ORIGIN=https://tool.ai-code8.com
