# 财务控制台 finance-web — Docker / Compose / 云托管（与 tool-web.env.example 同结构）
# cp deploy/tencent/finance-web.env.example deploy/tencent/finance-web.env

NODE_ENV=production

# 浏览器直连 book-mall API（CORS + credentials）；须与用户访问的主站公网 Origin 一致
NEXT_PUBLIC_BOOK_MALL_URL=https://book.ai-code8.com

# 云托管默认域临时调试：保留 *.sh.run.tcloudbase.com 时不强制纠正为正式域
# ALLOW_CLOUDBASE_DEFAULT_ORIGINS=1
