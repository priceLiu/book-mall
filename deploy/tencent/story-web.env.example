# 漫剧 story-web — Docker / CloudBase 用（复制为 story-web.env 后填写）
# cp deploy/tencent/story-web.env.example deploy/tencent/story-web.env

NODE_ENV=production

# 主站 Origin（SSO exchange / BFF 代理）
MAIN_SITE_ORIGIN=https://book.ai-code8.com
NEXT_PUBLIC_BOOK_MALL_URL=https://book.ai-code8.com
BOOK_MALL_URL=https://book.ai-code8.com

# 须与 book-mall 中完全一致（缺或错会 SSO missing_exchange_secret / exchange_401）
TOOLS_SSO_SERVER_SECRET=与主站相同至少16位
TOOLS_SSO_JWT_SECRET=与主站相同另一条至少16位

# 本服务公网 Origin
NEXT_PUBLIC_STORY_WEB_ORIGIN=https://story.ai-code8.com
STORY_PUBLIC_ORIGIN=https://story.ai-code8.com

# 工具站（页脚回链，可选）
NEXT_PUBLIC_TOOL_WEB_ORIGIN=https://tool.ai-code8.com

# 云托管默认域临时调试
# ALLOW_CLOUDBASE_DEFAULT_ORIGINS=1
